#!/bin/bash
# install.sh — Install luks-enroll into a chroot or live system.
#
# Usage:
#   sudo ./install.sh                  # install on live system
#   sudo ./install.sh /mnt/chroot      # install into chroot at /mnt/chroot

set -euo pipefail

CHROOT="${1:-}"
POLKIT_DIR="${CHROOT}/usr/share/polkit-1/actions"
DBUS_CONF_DIR="${CHROOT}/usr/share/dbus-1/system.d"
DBUS_SERVICE_DIR="${CHROOT}/usr/share/dbus-1/system-services"
SYSTEMD_DIR="${CHROOT}/lib/systemd/system"

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"

echo "==> Installing luks-enroll"

# Install the D-Bus system service (runs as root)
install -Dm755 "${SCRIPT_DIR}/src/luks-enroll-service.py" "${CHROOT}/usr/sbin/luks-enroll-service"

# Install the unprivileged GUI client
install -Dm755 "${SCRIPT_DIR}/src/luks-enroll.py" "${CHROOT}/usr/bin/luks-enroll"

# Install D-Bus system bus policy
install -Dm644 "${SCRIPT_DIR}/data/net.contemno.luks_enroll.conf" "${DBUS_CONF_DIR}/net.contemno.luks_enroll.conf"

# Install D-Bus system service activation file
install -Dm644 "${SCRIPT_DIR}/data/net.contemno.LuksEnroll.service" "${DBUS_SERVICE_DIR}/net.contemno.LuksEnroll.service"

# Install desktop launcher entry (management view)
APPS_DIR="${CHROOT}/usr/share/applications"
install -Dm644 "${SCRIPT_DIR}/data/luks-enroll.desktop" "${APPS_DIR}/luks-enroll.desktop"

# Install polkit policy
install -Dm644 "${SCRIPT_DIR}/data/net.contemno.luks-enroll.policy" "${POLKIT_DIR}/net.contemno.luks-enroll.policy"

# Install systemd service unit
install -Dm644 "${SCRIPT_DIR}/data/net.contemno.LuksEnroll.systemd.service" "${SYSTEMD_DIR}/net.contemno.LuksEnroll.service"

# Ensure dependencies are available inside the chroot
if [ -n "${CHROOT}" ]; then
    echo "==> Checking chroot dependencies"
    DEPS=(python3 python3-gi gir1.2-gtk-4.0 gir1.2-adw-1 systemd-cryptsetup polkitd)
    MISSING=()
    for dep in "${DEPS[@]}"; do
        if ! chroot "${CHROOT}" dpkg -s "${dep}" &>/dev/null; then
            MISSING+=("${dep}")
        fi
    done
    if [ ${#MISSING[@]} -gt 0 ]; then
        echo "    Missing packages: ${MISSING[*]}"
        echo "    Install with: chroot ${CHROOT} apt install -y ${MISSING[*]}"
    else
        echo "    All dependencies present."
    fi
fi

echo "==> Done. To run: luks-enroll"
