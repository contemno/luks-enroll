<node>
  <interface name="net.contemno.LuksEnroll1">
    <method name="DetectDevices">
      <arg direction="out" type="as" name="devices"/>
    </method>
    <method name="GetKeyslots">
      <arg direction="in" type="s" name="device"/>
      <arg direction="out" type="s" name="keyslots_json"/>
    </method>
    <method name="GetTokensByType">
      <arg direction="in" type="s" name="device"/>
      <arg direction="in" type="s" name="token_type"/>
      <arg direction="out" type="s" name="tokens_json"/>
    </method>
    <method name="FindPasswordKeyslots">
      <arg direction="in" type="s" name="device"/>
      <arg direction="out" type="ai" name="keyslots"/>
    </method>
    <method name="VerifyPassphrase">
      <arg direction="in" type="s" name="device"/>
      <arg direction="in" type="s" name="passphrase"/>
      <arg direction="out" type="b" name="success"/>
      <arg direction="out" type="i" name="keyslot"/>
    </method>
    <method name="UnlockWithToken">
      <arg direction="in" type="s" name="device"/>
      <arg direction="in" type="s" name="token_type"/>
      <arg direction="in" type="s" name="pin"/>
      <arg direction="out" type="b" name="success"/>
      <arg direction="out" type="i" name="keyslot"/>
    </method>
    <method name="EnrollFido2">
      <arg direction="in" type="s" name="device"/>
      <arg direction="in" type="s" name="passphrase"/>
      <arg direction="in" type="s" name="pin"/>
      <arg direction="in" type="s" name="fido2_device"/>
      <arg direction="in" type="s" name="unlock_method"/>
      <arg direction="in" type="s" name="unlock_pin"/>
      <arg direction="out" type="b" name="ok"/>
      <arg direction="out" type="s" name="stdout"/>
      <arg direction="out" type="s" name="stderr"/>
    </method>
    <method name="EnrollTpm2">
      <arg direction="in" type="s" name="device"/>
      <arg direction="in" type="s" name="passphrase"/>
      <arg direction="in" type="s" name="pin"/>
      <arg direction="in" type="s" name="pcrs"/>
      <arg direction="in" type="s" name="unlock_method"/>
      <arg direction="in" type="s" name="unlock_pin"/>
      <arg direction="out" type="b" name="ok"/>
      <arg direction="out" type="s" name="stdout"/>
      <arg direction="out" type="s" name="stderr"/>
    </method>
    <method name="EnrollRecoveryKey">
      <arg direction="in" type="s" name="device"/>
      <arg direction="in" type="s" name="passphrase"/>
      <arg direction="in" type="s" name="unlock_method"/>
      <arg direction="in" type="s" name="unlock_pin"/>
      <arg direction="out" type="b" name="ok"/>
      <arg direction="out" type="s" name="stdout"/>
      <arg direction="out" type="s" name="stderr"/>
    </method>
    <method name="WipeSlot">
      <arg direction="in" type="s" name="device"/>
      <arg direction="in" type="s" name="passphrase"/>
      <arg direction="in" type="s" name="unlock_method"/>
      <arg direction="in" type="s" name="pin"/>
      <arg direction="in" type="i" name="slot"/>
      <arg direction="out" type="b" name="ok"/>
      <arg direction="out" type="s" name="stdout"/>
      <arg direction="out" type="s" name="stderr"/>
    </method>
    <!--
      An empty passphrase means "no passphrase keyslot": the new container is
      formatted with a freshly generated volume key that the service caches,
      and the first enrollment wraps it (returning keyslot -1 here). A
      non-empty passphrase keeps the classic behavior of seeding a password
      keyslot. An existing path is refused rather than reformatted in place.
    -->
    <method name="CreateEncryptedImage">
      <arg direction="in" type="s" name="path"/>
      <arg direction="in" type="i" name="size_mb"/>
      <arg direction="in" type="s" name="passphrase"/>
      <arg direction="out" type="b" name="ok"/>
      <arg direction="out" type="i" name="keyslot"/>
      <arg direction="out" type="s" name="error"/>
    </method>
    <method name="DetectRemovableDevices">
      <arg direction="out" type="s" name="devices_json"/>
    </method>
    <method name="GetDeviceInfo">
      <arg direction="in" type="s" name="device"/>
      <arg direction="out" type="s" name="info_json"/>
    </method>
    <method name="FormatPartition">
      <arg direction="in" type="s" name="device"/>
      <arg direction="in" type="s" name="passphrase"/>
      <arg direction="out" type="b" name="ok"/>
      <arg direction="out" type="s" name="partition"/>
      <arg direction="out" type="s" name="stderr"/>
    </method>
    <method name="EnrollPassphrase">
      <arg direction="in" type="s" name="device"/>
      <arg direction="in" type="s" name="existing_passphrase"/>
      <arg direction="in" type="s" name="new_passphrase"/>
      <arg direction="in" type="s" name="unlock_method"/>
      <arg direction="in" type="s" name="unlock_pin"/>
      <arg direction="out" type="b" name="ok"/>
      <arg direction="out" type="s" name="stdout"/>
      <arg direction="out" type="s" name="stderr"/>
    </method>
    <method name="GetSetting">
      <arg direction="in" type="s" name="key"/>
      <arg direction="out" type="s" name="value"/>
    </method>
    <method name="SetSetting">
      <arg direction="in" type="s" name="key"/>
      <arg direction="in" type="s" name="value"/>
      <arg direction="out" type="b" name="ok"/>
    </method>
    <method name="CheckFido2Enrolled">
      <arg direction="in" type="s" name="device"/>
      <arg direction="in" type="as" name="fido2_dev_paths"/>
      <arg direction="out" type="as" name="enrolled_hidraw_paths"/>
    </method>
    <method name="Authenticate">
      <arg direction="out" type="b" name="authorized"/>
    </method>
    <method name="GetSystemdVersion">
      <arg direction="out" type="i" name="version"/>
    </method>

    <!--
      File-descriptor variants. For encrypted-container files the client
      opens the file it owns and passes the descriptor (type 'h'); the
      service operates on /proc/self/fd/N. This lets the sandboxed service
      manage a user-owned container's LUKS header under
      ProtectHome=read-only without relaxing the sandbox, and removes the
      path allowlist, the TOCTOU window, and the polkit round-trip
      (possession of a writable descriptor is the capability). Block
      devices keep using the string-path methods above.
    -->
    <method name="GetKeyslotsFd">
      <arg direction="in" type="h" name="fd"/>
      <arg direction="out" type="s" name="keyslots_json"/>
    </method>
    <method name="GetTokensByTypeFd">
      <arg direction="in" type="h" name="fd"/>
      <arg direction="in" type="s" name="token_type"/>
      <arg direction="out" type="s" name="tokens_json"/>
    </method>
    <method name="FindPasswordKeyslotsFd">
      <arg direction="in" type="h" name="fd"/>
      <arg direction="out" type="ai" name="keyslots"/>
    </method>
    <method name="VerifyPassphraseFd">
      <arg direction="in" type="h" name="fd"/>
      <arg direction="in" type="s" name="passphrase"/>
      <arg direction="out" type="b" name="success"/>
      <arg direction="out" type="i" name="keyslot"/>
    </method>
    <method name="UnlockWithTokenFd">
      <arg direction="in" type="h" name="fd"/>
      <arg direction="in" type="s" name="token_type"/>
      <arg direction="in" type="s" name="pin"/>
      <arg direction="out" type="b" name="success"/>
      <arg direction="out" type="i" name="keyslot"/>
    </method>
    <method name="EnrollFido2Fd">
      <arg direction="in" type="h" name="fd"/>
      <arg direction="in" type="s" name="passphrase"/>
      <arg direction="in" type="s" name="pin"/>
      <arg direction="in" type="s" name="fido2_device"/>
      <arg direction="in" type="s" name="unlock_method"/>
      <arg direction="in" type="s" name="unlock_pin"/>
      <arg direction="out" type="b" name="ok"/>
      <arg direction="out" type="s" name="stdout"/>
      <arg direction="out" type="s" name="stderr"/>
    </method>
    <method name="EnrollTpm2Fd">
      <arg direction="in" type="h" name="fd"/>
      <arg direction="in" type="s" name="passphrase"/>
      <arg direction="in" type="s" name="pin"/>
      <arg direction="in" type="s" name="pcrs"/>
      <arg direction="in" type="s" name="unlock_method"/>
      <arg direction="in" type="s" name="unlock_pin"/>
      <arg direction="out" type="b" name="ok"/>
      <arg direction="out" type="s" name="stdout"/>
      <arg direction="out" type="s" name="stderr"/>
    </method>
    <method name="EnrollRecoveryKeyFd">
      <arg direction="in" type="h" name="fd"/>
      <arg direction="in" type="s" name="passphrase"/>
      <arg direction="in" type="s" name="unlock_method"/>
      <arg direction="in" type="s" name="unlock_pin"/>
      <arg direction="out" type="b" name="ok"/>
      <arg direction="out" type="s" name="stdout"/>
      <arg direction="out" type="s" name="stderr"/>
    </method>
    <method name="EnrollPassphraseFd">
      <arg direction="in" type="h" name="fd"/>
      <arg direction="in" type="s" name="existing_passphrase"/>
      <arg direction="in" type="s" name="new_passphrase"/>
      <arg direction="in" type="s" name="unlock_method"/>
      <arg direction="in" type="s" name="unlock_pin"/>
      <arg direction="out" type="b" name="ok"/>
      <arg direction="out" type="s" name="stdout"/>
      <arg direction="out" type="s" name="stderr"/>
    </method>
    <method name="WipeSlotFd">
      <arg direction="in" type="h" name="fd"/>
      <arg direction="in" type="s" name="passphrase"/>
      <arg direction="in" type="s" name="unlock_method"/>
      <arg direction="in" type="s" name="pin"/>
      <arg direction="in" type="i" name="slot"/>
      <arg direction="out" type="b" name="ok"/>
      <arg direction="out" type="s" name="stdout"/>
      <arg direction="out" type="s" name="stderr"/>
    </method>
    <method name="GetDeviceInfoFd">
      <arg direction="in" type="h" name="fd"/>
      <arg direction="out" type="s" name="info_json"/>
    </method>
    <method name="CheckFido2EnrolledFd">
      <arg direction="in" type="h" name="fd"/>
      <arg direction="in" type="as" name="fido2_dev_paths"/>
      <arg direction="out" type="as" name="enrolled_hidraw_paths"/>
    </method>
    <!-- Empty passphrase => keyslot-less format with a cached volume key, as
         for CreateEncryptedImage above (keyslot -1). The client owns the fd
         and opens it O_CREAT|O_EXCL, so an existing file is never clobbered. -->
    <method name="CreateEncryptedImageFd">
      <arg direction="in" type="h" name="fd"/>
      <arg direction="in" type="i" name="size_mb"/>
      <arg direction="in" type="s" name="passphrase"/>
      <arg direction="out" type="b" name="ok"/>
      <arg direction="out" type="i" name="keyslot"/>
      <arg direction="out" type="s" name="error"/>
    </method>
  </interface>
</node>
