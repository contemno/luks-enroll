# --- Passphrase spec -------------------------------------------------------


def _passphrase_setup_inputs(page, group):
    page._pw_row = Adw.ActionRow(title="New Passphrase")
    page._pw_entry = Gtk.PasswordEntry()
    page._pw_entry.set_show_peek_icon(True)
    page._pw_entry.set_valign(Gtk.Align.CENTER)
    page._pw_entry.set_hexpand(True)
    page._pw_row.add_suffix(page._pw_entry)
    group.add(page._pw_row)

    page._pw_confirm_row = Adw.ActionRow(title="Confirm Passphrase")
    page._pw_confirm = Gtk.PasswordEntry()
    page._pw_confirm.set_show_peek_icon(True)
    page._pw_confirm.set_valign(Gtk.Align.CENTER)
    page._pw_confirm.set_hexpand(True)
    page._pw_confirm.connect("activate", lambda _: page._do_enroll())
    page._pw_confirm_row.add_suffix(page._pw_confirm)
    group.add(page._pw_confirm_row)


def _passphrase_validate(page):
    pw = page._pw_entry.get_text()
    confirm = page._pw_confirm.get_text()
    if not pw:
        return None, "Passphrase cannot be empty."
    if pw != confirm:
        return None, "Passphrases do not match."
    return (pw,), None


def _passphrase_on_enroll_start(page):
    page._pw_row.set_sensitive(False)
    page._pw_confirm_row.set_sensitive(False)


def _passphrase_on_enroll_done(page, ok):
    page._pw_row.set_sensitive(True)
    page._pw_confirm_row.set_sensitive(True)


PASSPHRASE_SPEC = EnrollSpec(
