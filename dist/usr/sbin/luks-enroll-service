def detect_luks_devices():
    """Return a list of LUKS block devices found on the system.

    Strategy: parse /etc/crypttab for source devices, then scan via blkid.
    Works inside a chroot as long as /dev is mounted.
    Deduplicates by resolved path.
    """
    found = []
    seen = set()

    # Try crypttab first
    try:
        with open("/etc/crypttab") as f:
            for line in f:
                line = line.strip()
                if not line or line.startswith("#"):
                    continue
                parts = line.split()
                if len(parts) >= 2:
                    src = parts[1]
                    dev = None
                    if src.startswith("UUID="):
                        uuid = src.split("=", 1)[1]
                        path = f"/dev/disk/by-uuid/{uuid}"
                        if os.path.exists(path):
                            dev = os.path.realpath(path)
                    elif os.path.exists(src):
                        dev = os.path.realpath(src)
                    if dev and dev not in seen:
                        found.append(dev)
                        seen.add(dev)
    except FileNotFoundError:
        pass

    # Also scan via libblkid for any LUKS partitions not in crypttab
    for dev in _blkid_find_luks_devices():
        if dev:
            real = os.path.realpath(dev)
            if real not in seen:
                found.append(real)
                seen.add(real)

    return found


def _load_libblkid():
    """Load libblkid and set up function prototypes."""
    lib = ctypes.CDLL("libblkid.so.1")

    # Probe API (per-device tag lookup)
    lib.blkid_new_probe_from_filename.restype = ctypes.c_void_p
    lib.blkid_new_probe_from_filename.argtypes = [ctypes.c_char_p]

    lib.blkid_free_probe.restype = None
    lib.blkid_free_probe.argtypes = [ctypes.c_void_p]

    lib.blkid_do_safeprobe.restype = ctypes.c_int
    lib.blkid_do_safeprobe.argtypes = [ctypes.c_void_p]

    lib.blkid_probe_set_superblocks_flags.restype = ctypes.c_int
    lib.blkid_probe_set_superblocks_flags.argtypes = [ctypes.c_void_p, ctypes.c_int]

    lib.blkid_probe_lookup_value.restype = ctypes.c_int
    lib.blkid_probe_lookup_value.argtypes = [
        ctypes.c_void_p,                    # probe
        ctypes.c_char_p,                    # name
        ctypes.POINTER(ctypes.c_char_p),    # data (out)
        ctypes.POINTER(ctypes.c_size_t),    # len (out, may be NULL)
    ]

    # Cache/iterate API (system-wide LUKS device discovery)
    lib.blkid_get_cache.restype = ctypes.c_int
    lib.blkid_get_cache.argtypes = [
        ctypes.POINTER(ctypes.c_void_p),    # cache (out)
        ctypes.c_char_p,                    # filename (NULL = default)
    ]

    lib.blkid_put_cache.restype = None
    lib.blkid_put_cache.argtypes = [ctypes.c_void_p]

    lib.blkid_probe_all.restype = ctypes.c_int
    lib.blkid_probe_all.argtypes = [ctypes.c_void_p]

    lib.blkid_dev_iterate_begin.restype = ctypes.c_void_p
    lib.blkid_dev_iterate_begin.argtypes = [ctypes.c_void_p]

    lib.blkid_dev_iterate_end.restype = None
    lib.blkid_dev_iterate_end.argtypes = [ctypes.c_void_p]

    lib.blkid_dev_set_search.restype = ctypes.c_int
    lib.blkid_dev_set_search.argtypes = [
        ctypes.c_void_p,    # iter
        ctypes.c_char_p,    # search_type
        ctypes.c_char_p,    # search_value
    ]

    lib.blkid_dev_next.restype = ctypes.c_int
    lib.blkid_dev_next.argtypes = [
        ctypes.c_void_p,                    # iter
        ctypes.POINTER(ctypes.c_void_p),    # dev (out)
    ]

    lib.blkid_dev_devname.restype = ctypes.c_char_p
    lib.blkid_dev_devname.argtypes = [ctypes.c_void_p]

    lib.blkid_do_probe.restype = ctypes.c_int
    lib.blkid_do_probe.argtypes = [ctypes.c_void_p]

    lib.blkid_probe_enable_superblocks.restype = ctypes.c_int
    lib.blkid_probe_enable_superblocks.argtypes = [ctypes.c_void_p, ctypes.c_int]

    lib.blkid_probe_enable_partitions.restype = ctypes.c_int
    lib.blkid_probe_enable_partitions.argtypes = [ctypes.c_void_p, ctypes.c_int]

    lib.blkid_probe_set_partitions_flags.restype = ctypes.c_int
    lib.blkid_probe_set_partitions_flags.argtypes = [ctypes.c_void_p, ctypes.c_int]

    return lib


# BLKID_SUBLKS flags for blkid_probe_set_superblocks_flags
_BLKID_SUBLKS_LABEL = (1 << 1)
_BLKID_SUBLKS_TYPE = (1 << 5)
_BLKID_SUBLKS_MAGIC = (1 << 9)
_BLKID_PARTS_MAGIC = (1 << 1)


def _wipefs(device):
    """Erase all filesystem/partition-table signatures using libblkid probe API.

    Returns (ok: bool, stderr: str).
    """
    try:
        lib = _load_libblkid()
    except OSError as e:
        return False, f"failed to load libblkid: {e}"

    probe = lib.blkid_new_probe_from_filename(device.encode())
    if not probe:
        return False, f"blkid_new_probe_from_filename failed for {device}"

    try:
        lib.blkid_probe_enable_superblocks(probe, 1)
        lib.blkid_probe_set_superblocks_flags(probe, _BLKID_SUBLKS_MAGIC)
        lib.blkid_probe_enable_partitions(probe, 1)
        lib.blkid_probe_set_partitions_flags(probe, _BLKID_PARTS_MAGIC)

        while True:
            rc = lib.blkid_do_probe(probe)
            if rc != 0:
                if rc < 0:
                    return False, "blkid_do_probe error"
                break  # rc == 1: no more signatures

            offset_val = ctypes.c_char_p()
            mag_val = ctypes.c_char_p()
            mag_len = ctypes.c_size_t()

            if lib.blkid_probe_lookup_value(
                    probe, b"SBMAGIC_OFFSET",
                    ctypes.byref(offset_val), None) != 0:
                continue
            if lib.blkid_probe_lookup_value(
                    probe, b"SBMAGIC",
                    ctypes.byref(mag_val), ctypes.byref(mag_len)) != 0:
                continue

            offset = int(offset_val.value)
            length = mag_len.value
            if length == 0:
                continue

            with open(device, "r+b") as fp:
                fp.seek(offset)
                fp.write(b"\x00" * length)

        return True, ""
    finally:
        lib.blkid_free_probe(probe)


def _blkid_find_luks_devices():
    """Find all LUKS devices on the system using libblkid cache API.

    Returns a list of device path strings (e.g. ['/dev/sda2', '/dev/nvme0n1p3']).
    """
    try:
        lib = _load_libblkid()
    except OSError:
        return []

    cache = ctypes.c_void_p()
    if lib.blkid_get_cache(ctypes.byref(cache), None) != 0:
        return []

    try:
        lib.blkid_probe_all(cache)
        it = lib.blkid_dev_iterate_begin(cache)
        if not it:
            return []
        try:
            lib.blkid_dev_set_search(it, b"TYPE", b"crypto_LUKS")
            devices = []
            dev = ctypes.c_void_p()
            while lib.blkid_dev_next(it, ctypes.byref(dev)) == 0:
                name = lib.blkid_dev_devname(dev)
                if name:
                    devices.append(name.decode())
            return devices
        finally:
            lib.blkid_dev_iterate_end(it)
    finally:
        lib.blkid_put_cache(cache)


def _load_libfdisk():
    """Load libfdisk and set up function prototypes."""
    lib = ctypes.CDLL("libfdisk.so.1")

    lib.fdisk_new_context.restype = ctypes.c_void_p
    lib.fdisk_new_context.argtypes = []

    lib.fdisk_unref_context.restype = None
    lib.fdisk_unref_context.argtypes = [ctypes.c_void_p]

    lib.fdisk_assign_device.restype = ctypes.c_int
    lib.fdisk_assign_device.argtypes = [
        ctypes.c_void_p,    # ctx
        ctypes.c_char_p,    # fname
        ctypes.c_int,       # readonly
    ]

    lib.fdisk_deassign_device.restype = ctypes.c_int
    lib.fdisk_deassign_device.argtypes = [
        ctypes.c_void_p,    # ctx
        ctypes.c_int,       # nosync
    ]

    lib.fdisk_create_disklabel.restype = ctypes.c_int
    lib.fdisk_create_disklabel.argtypes = [
        ctypes.c_void_p,    # ctx
        ctypes.c_char_p,    # name (e.g. b"gpt")
    ]

    lib.fdisk_write_disklabel.restype = ctypes.c_int
    lib.fdisk_write_disklabel.argtypes = [ctypes.c_void_p]

    lib.fdisk_new_partition.restype = ctypes.c_void_p
    lib.fdisk_new_partition.argtypes = []

    lib.fdisk_unref_partition.restype = None
    lib.fdisk_unref_partition.argtypes = [ctypes.c_void_p]

    lib.fdisk_partition_set_number.restype = ctypes.c_int
    lib.fdisk_partition_set_number.argtypes = [ctypes.c_void_p, ctypes.c_size_t]

    lib.fdisk_partition_start_follow_default.restype = ctypes.c_int
    lib.fdisk_partition_start_follow_default.argtypes = [
        ctypes.c_void_p,    # pa
        ctypes.c_int,       # enable
    ]

    lib.fdisk_partition_end_follow_default.restype = ctypes.c_int
    lib.fdisk_partition_end_follow_default.argtypes = [
        ctypes.c_void_p,    # pa
        ctypes.c_int,       # enable
    ]

    lib.fdisk_partition_set_type.restype = ctypes.c_int
    lib.fdisk_partition_set_type.argtypes = [
        ctypes.c_void_p,    # pa
        ctypes.c_void_p,    # type
    ]

    lib.fdisk_new_parttype.restype = ctypes.c_void_p
    lib.fdisk_new_parttype.argtypes = []

    lib.fdisk_unref_parttype.restype = None
    lib.fdisk_unref_parttype.argtypes = [ctypes.c_void_p]

    lib.fdisk_parttype_set_typestr.restype = ctypes.c_int
    lib.fdisk_parttype_set_typestr.argtypes = [
        ctypes.c_void_p,    # type
        ctypes.c_char_p,    # str (GUID)
    ]

    lib.fdisk_add_partition.restype = ctypes.c_int
    lib.fdisk_add_partition.argtypes = [
        ctypes.c_void_p,                    # ctx
        ctypes.c_void_p,                    # pa
        ctypes.POINTER(ctypes.c_size_t),    # partno (out, may be NULL)
    ]

    return lib


# Linux LUKS partition type GUID (sgdisk shortcode 8309)
_LUKS_PARTITION_TYPE_GUID = "CA7D7CCB-63ED-4C53-861C-1742536059CC"


def _sgdisk_zap_and_partition(device):
    """Wipe partition table and create a single GPT LUKS partition using libfdisk.

    Equivalent to:
        sgdisk --zap-all <device>
        sgdisk -n 1:0:0 -t 1:8309 <device>

    Returns (ok: bool, stderr: str).
    """
    try:
        lib = _load_libfdisk()
    except OSError as e:
        return False, f"failed to load libfdisk: {e}"

    ctx = None
    pa = None
    pt = None
    device_assigned = False

    try:
        ctx = lib.fdisk_new_context()
        if not ctx:
            return False, "fdisk_new_context() failed"

        rc = lib.fdisk_assign_device(ctx, device.encode(), 0)
        if rc != 0:
            return False, f"fdisk_assign_device({device}) failed: rc={rc}"
        device_assigned = True

        # Create fresh GPT — this wipes any existing partition table
        rc = lib.fdisk_create_disklabel(ctx, b"gpt")
        if rc != 0:
            return False, f"fdisk_create_disklabel(gpt) failed: rc={rc}"

        # Build partition type (Linux LUKS GUID)
        pt = lib.fdisk_new_parttype()
        if not pt:
            return False, "fdisk_new_parttype() failed"
        rc = lib.fdisk_parttype_set_typestr(
            pt, _LUKS_PARTITION_TYPE_GUID.encode()
        )
        if rc != 0:
            return False, f"fdisk_parttype_set_typestr() failed: rc={rc}"

        # Build partition: number 0 (first), default start/end (use all space)
        pa = lib.fdisk_new_partition()
        if not pa:
            return False, "fdisk_new_partition() failed"

        lib.fdisk_partition_set_number(pa, 0)
        lib.fdisk_partition_start_follow_default(pa, 1)
        lib.fdisk_partition_end_follow_default(pa, 1)
        lib.fdisk_partition_set_type(pa, pt)

        rc = lib.fdisk_add_partition(ctx, pa, None)
        if rc != 0:
            return False, f"fdisk_add_partition() failed: rc={rc}"

        rc = lib.fdisk_write_disklabel(ctx)
        if rc != 0:
            return False, f"fdisk_write_disklabel() failed: rc={rc}"

        rc = lib.fdisk_deassign_device(ctx, 0)
        device_assigned = False
        if rc != 0:
            return False, f"fdisk_deassign_device() failed: rc={rc}"

        return True, ""

    finally:
        if pa:
            lib.fdisk_unref_partition(pa)
        if pt:
            lib.fdisk_unref_parttype(pt)
        if device_assigned:
            lib.fdisk_deassign_device(ctx, 0)
        if ctx:
            lib.fdisk_unref_context(ctx)


def _load_libcryptsetup():
    """Load libcryptsetup and set up function prototypes."""
    lib = ctypes.CDLL("libcryptsetup.so.12")

    lib.crypt_init.restype = ctypes.c_int
    lib.crypt_init.argtypes = [ctypes.POINTER(ctypes.c_void_p), ctypes.c_char_p]

    lib.crypt_load.restype = ctypes.c_int
    lib.crypt_load.argtypes = [ctypes.c_void_p, ctypes.c_char_p, ctypes.c_void_p]

    lib.crypt_dump_json.restype = ctypes.c_int
    lib.crypt_dump_json.argtypes = [
        ctypes.c_void_p,
        ctypes.POINTER(ctypes.c_char_p),
        ctypes.c_uint32,
    ]

    lib.crypt_format.restype = ctypes.c_int
    lib.crypt_format.argtypes = [
        ctypes.c_void_p,  # cd
        ctypes.c_char_p,  # type
        ctypes.c_char_p,  # cipher
        ctypes.c_char_p,  # cipher_mode
        ctypes.c_char_p,  # uuid
        ctypes.c_char_p,  # volume_key
        ctypes.c_size_t,  # volume_key_size
        ctypes.c_void_p,  # params
    ]

    lib.crypt_keyslot_add_by_volume_key.restype = ctypes.c_int
    lib.crypt_keyslot_add_by_volume_key.argtypes = [
        ctypes.c_void_p,  # cd
        ctypes.c_int,  # keyslot
        ctypes.c_char_p,  # volume_key
        ctypes.c_size_t,  # volume_key_size
        ctypes.c_char_p,  # passphrase
        ctypes.c_size_t,  # passphrase_size
    ]

    lib.crypt_set_pbkdf_type.restype = ctypes.c_int
    lib.crypt_set_pbkdf_type.argtypes = [ctypes.c_void_p, ctypes.c_void_p]

    lib.crypt_free.restype = None
    lib.crypt_free.argtypes = [ctypes.c_void_p]

    # crypt_activate_by_token(cd, name, token, usrptr, usrptr_size, flags)
    # name=NULL does a dry-run (verify only, no dm-crypt activation)
    # token=-1 tries all tokens (CRYPT_ANY_TOKEN)
    lib.crypt_activate_by_token_pin.restype = ctypes.c_int
    lib.crypt_activate_by_token_pin.argtypes = [
        ctypes.c_void_p,  # cd
        ctypes.c_char_p,  # name (NULL = verify only)
        ctypes.c_char_p,  # type (token type filter, NULL = any)
        ctypes.c_int,     # token (-1 = any)
        ctypes.c_char_p,  # pin
        ctypes.c_size_t,  # pin_size
        ctypes.c_void_p,  # usrptr
        ctypes.c_uint32,  # flags
    ]

    lib.crypt_activate_by_passphrase.restype = ctypes.c_int
    lib.crypt_activate_by_passphrase.argtypes = [
        ctypes.c_void_p,  # cd
        ctypes.c_char_p,  # name (NULL = just verify)
        ctypes.c_int,     # keyslot (-1 = any)
        ctypes.c_char_p,  # passphrase
        ctypes.c_size_t,  # passphrase_size
        ctypes.c_uint32,  # flags
    ]

    lib.crypt_keyslot_add_by_passphrase.restype = ctypes.c_int
    lib.crypt_keyslot_add_by_passphrase.argtypes = [
        ctypes.c_void_p,  # cd
        ctypes.c_int,     # keyslot
        ctypes.c_char_p,  # existing passphrase
        ctypes.c_size_t,  # existing passphrase size
        ctypes.c_char_p,  # new passphrase
        ctypes.c_size_t,  # new passphrase size
    ]

    lib.crypt_get_volume_key_size.restype = ctypes.c_int
    lib.crypt_get_volume_key_size.argtypes = [ctypes.c_void_p]

    lib.crypt_volume_key_get.restype = ctypes.c_int
    lib.crypt_volume_key_get.argtypes = [
        ctypes.c_void_p,                    # cd
        ctypes.c_int,                       # keyslot
        ctypes.c_char_p,                    # volume_key (output buffer)
        ctypes.POINTER(ctypes.c_size_t),    # volume_key_size (in/out)
        ctypes.c_char_p,                    # passphrase
        ctypes.c_size_t,                    # passphrase_size
    ]

    lib.crypt_keyslot_destroy.restype = ctypes.c_int
    lib.crypt_keyslot_destroy.argtypes = [
        ctypes.c_void_p,  # cd
        ctypes.c_int,     # keyslot
    ]

    lib.crypt_token_json_set.restype = ctypes.c_int
    lib.crypt_token_json_set.argtypes = [
        ctypes.c_void_p,  # cd
        ctypes.c_int,     # token (-1 = auto-allocate)
        ctypes.c_char_p,  # json (NULL = remove token)
    ]

    lib.crypt_token_json_get.restype = ctypes.c_int
    lib.crypt_token_json_get.argtypes = [
        ctypes.c_void_p,                    # cd
        ctypes.c_int,                       # token
        ctypes.POINTER(ctypes.c_char_p),    # json (output)
    ]

    return lib


def _get_luks_json(device):
    """Return parsed LUKS2 JSON metadata via libcryptsetup, or None on failure."""
    try:
        lib = _load_libcryptsetup()
    except OSError:
        return None

    cd = ctypes.c_void_p()
    if lib.crypt_init(ctypes.byref(cd), device.encode()) != 0:
        return None
    try:
        if lib.crypt_load(cd, b"LUKS2", None) != 0:
            return None
        json_ptr = ctypes.c_char_p()
        if lib.crypt_dump_json(cd, ctypes.byref(json_ptr), 0) != 0:
            return None
        return json.loads(json_ptr.value.decode())
    finally:
        lib.crypt_free(cd)


def list_luks_keyslots(device):
    """Return a dict mapping slot numbers to their types via libcryptsetup."""
    meta = _get_luks_json(device)
    if not meta:
        return {}
    try:
        return {
            int(s): info.get("type", "unknown")
            for s, info in meta.get("keyslots", {}).items()
        }
    except (KeyError, ValueError):
        return {}


def find_tokens_by_type(device, token_type):
    """Return list of (token_id, keyslot_list) for tokens matching the given type.

    token_type should be e.g. 'systemd-fido2', 'systemd-tpm2', 'systemd-recovery'.
    """
    meta = _get_luks_json(device)
    if not meta:
        return []
    result = []
    try:
        for tid, tinfo in meta.get("tokens", {}).items():
            if tinfo.get("type") == token_type:
                slots = [int(s) for s in tinfo.get("keyslots", [])]
                result.append((int(tid), slots))
    except (KeyError, ValueError):
        pass
    return result


def find_password_keyslots(device):
    """Return list of keyslot numbers that are password (passphrase) slots."""
    meta = _get_luks_json(device)
    if not meta:
        return []
    try:
        tokens = meta.get("tokens", {})
        managed_slots = set()
        for _tid, tinfo in tokens.items():
            for ks in tinfo.get("keyslots", []):
                managed_slots.add(int(ks))
        return sorted(
            int(s) for s in meta.get("keyslots", {}) if int(s) not in managed_slots
        )
    except (KeyError, ValueError):
        return []


def verify_luks_passphrase(device, passphrase):
    """Verify a passphrase against a LUKS device. Returns (ok, keyslot_or_error)."""
    try:
        lib = _load_libcryptsetup()
    except OSError:
        return False, "libcryptsetup not available"

    cd = ctypes.c_void_p()
    if lib.crypt_init(ctypes.byref(cd), device.encode()) != 0:
        return False, "Failed to open device"
    try:
        if lib.crypt_load(cd, b"LUKS2", None) != 0:
            return False, "Failed to load LUKS2 header"
        pw = passphrase.encode()
        ret = lib.crypt_activate_by_passphrase(cd, None, -1, pw, len(pw), 0)
        if ret >= 0:
            return True, ret  # ret is the keyslot number
        return False, "Incorrect passphrase or recovery key"
    finally:
        lib.crypt_free(cd)


# Cache volume keys extracted during token unlock to avoid requiring
# a second FIDO2 touch or TPM2 unseal for subsequent operations.
# Keyed by os.path.realpath(device).
_volume_key_cache = {}  # device -> (vk_bytes, vk_size, timestamp)
_volume_key_cache_lock = threading.Lock()
_VOLUME_KEY_CACHE_TTL = 120  # seconds


def _clear_volume_key_cache(device):
    """Remove cached volume key for a device."""
    real_dev = os.path.realpath(device)
    with _volume_key_cache_lock:
        _volume_key_cache.pop(real_dev, None)


def verify_luks_token(device, token_type, pin=""):
    """Verify unlock via a LUKS2 token (TPM2/FIDO2). Returns (ok, keyslot_or_error).

    Derives the passphrase via our own FIDO2/TPM2 ctypes code, then uses
    crypt_volume_key_get to both verify AND extract the volume key in a
    single touch.  The volume key is cached so subsequent enrollment
    operations don't need a second FIDO2 touch or TPM2 unseal.

    token_type: e.g. "systemd-tpm2" or "systemd-fido2"
    pin: optional PIN for TPM2-with-pin or FIDO2 PIN
    """
    _VALID_TOKEN_TYPES = ("systemd-fido2", "systemd-tpm2")
    if token_type not in _VALID_TOKEN_TYPES:
        raise ValueError("Unsupported token type")
    try:
        pw = _derive_passphrase_from_token(device, token_type, pin)
    except Exception as e:
        return False, str(e)

    try:
        lib = _load_libcryptsetup()
    except OSError:
        return False, "libcryptsetup not available"

    cd = ctypes.c_void_p()
    if lib.crypt_init(ctypes.byref(cd), device.encode()) != 0:
        return False, "Failed to open device"
    try:
        if lib.crypt_load(cd, b"LUKS2", None) != 0:
            return False, "Failed to load LUKS2 header"

        key_size = ctypes.c_size_t(lib.crypt_get_volume_key_size(cd))
        vk_buf = ctypes.create_string_buffer(key_size.value)
        ret = lib.crypt_volume_key_get(
            cd, -1, vk_buf, ctypes.byref(key_size), pw, len(pw),
        )
        if ret >= 0:
            real_dev = os.path.realpath(device)
            with _volume_key_cache_lock:
                _volume_key_cache[real_dev] = (
                    vk_buf.raw[:key_size.value], key_size.value, time.monotonic()
                )
            return True, ret  # ret is the keyslot number
        return False, f"Token unlock failed (error {ret})"
    finally:
        lib.crypt_free(cd)


def _luks_format_device(path, passphrase):
    """LUKS2-format a device or file via libcryptsetup.

    Returns the keyslot number on success, raises RuntimeError on failure.
    """
    lib = _load_libcryptsetup()
    cd = ctypes.c_void_p()
    if lib.crypt_init(ctypes.byref(cd), path.encode()) != 0:
        raise RuntimeError("crypt_init failed")
    try:
        ret = lib.crypt_format(
            cd, b"LUKS2", b"aes", b"xts-plain64", None, None, 64, None
        )
        if ret != 0:
            raise RuntimeError(f"crypt_format failed: {ret}")
        pw = passphrase.encode()
        ret = lib.crypt_keyslot_add_by_volume_key(cd, -1, None, 0, pw, len(pw))
        if ret < 0:
            raise RuntimeError(f"crypt_keyslot_add_by_volume_key failed: {ret}")
        return ret
    finally:
        lib.crypt_free(cd)


def format_luks_image(path, size_mb=256, passphrase="test"):
    """Create and LUKS2-format an encrypted image file via libcryptsetup."""
    if not (1 <= size_mb <= 8192):
        raise ValueError(f"size_mb must be between 1 and 8192, got {size_mb}")
    with open(path, "wb") as f:
        f.seek(size_mb * 1024 * 1024 - 1)
        f.write(b"\0")

    return _luks_format_device(path, passphrase)


# ---------------------------------------------------------------------------
# Recovery key generation (modhex format, matches systemd-cryptenroll)
# ---------------------------------------------------------------------------

_MODHEX = "cbdefghijklnrtuv"


def _make_recovery_key():
    """Generate a 256-bit recovery key in modhex dash-separated format.

    Matches the format produced by systemd-cryptenroll --recovery-key.
    Returns a string like "cbdefghi-jklnrtuv-..." (8 groups of 8 chars).
    """
    raw = os.urandom(32)
    chars = []
    for byte in raw:
        chars.append(_MODHEX[byte >> 4])
        chars.append(_MODHEX[byte & 0x0F])
    return "-".join("".join(chars[i:i + 8]) for i in range(0, 64, 8))


# ---------------------------------------------------------------------------
# Volume key extraction (centralized unlock helper)
# ---------------------------------------------------------------------------

def _get_volume_key(device, unlock_method, passphrase, unlock_pin=""):
    """Get the volume key for a LUKS2 device.

    Returns (volume_key_bytes, key_size) on success, raises RuntimeError on failure.
    Supports passphrase, FIDO2 token, and TPM2 token unlock methods.
    """
    _VALID_UNLOCK_METHODS = ("passphrase", "systemd-fido2", "systemd-tpm2")
    if unlock_method not in _VALID_UNLOCK_METHODS:
        raise ValueError(f"Invalid unlock method: {unlock_method!r}")
    # For token-based unlock, use cached volume key from verify_luks_token()
    # to avoid requiring a second FIDO2 touch or TPM2 unseal.
    if unlock_method in ("systemd-fido2", "systemd-tpm2"):
        real_dev = os.path.realpath(device)
        with _volume_key_cache_lock:
            cached = _volume_key_cache.get(real_dev)
            if cached:
                vk, vk_size, ts = cached
                if (time.monotonic() - ts) < _VOLUME_KEY_CACHE_TTL:
                    return vk, vk_size
                else:
                    _volume_key_cache.pop(real_dev, None)

    lib = _load_libcryptsetup()
    cd = ctypes.c_void_p()
    if lib.crypt_init(ctypes.byref(cd), device.encode()) != 0:
        raise RuntimeError("Failed to open device")
    try:
        if lib.crypt_load(cd, b"LUKS2", None) != 0:
            raise RuntimeError("Failed to load LUKS2 header")

        # Determine the passphrase to use for volume key extraction
        if unlock_method in ("systemd-fido2", "systemd-tpm2"):
            pw = _derive_passphrase_from_token(device, unlock_method, unlock_pin)
        else:
            pw = passphrase.encode() if passphrase else b""

        key_size = ctypes.c_size_t(lib.crypt_get_volume_key_size(cd))
        vk_buf = ctypes.create_string_buffer(key_size.value)
        ret = lib.crypt_volume_key_get(
            cd, -1, vk_buf, ctypes.byref(key_size), pw, len(pw)
        )
        if ret < 0:
            raise RuntimeError(f"Failed to get volume key (error {ret})")
        return vk_buf.raw[:key_size.value], key_size.value
    finally:
        lib.crypt_free(cd)


def _derive_passphrase_from_token(device, token_type, pin=""):
    """Derive the passphrase bytes from a LUKS2 token (FIDO2 or TPM2).

    Used by _get_volume_key when unlock_method is token-based.
    Returns raw bytes suitable for crypt_volume_key_get.
    """
    if token_type == "systemd-fido2":
        raw = _fido2_unlock_from_token(device, pin)
        return base64.b64encode(raw)
    elif token_type == "systemd-tpm2":
        raw = _tpm2_unseal_from_token(device, pin)
        return base64.b64encode(raw)
    else:
        raise RuntimeError(f"Unknown token type: {token_type}")


# ---------------------------------------------------------------------------
# Keyslot / token helpers via libcryptsetup
# ---------------------------------------------------------------------------

class _CryptPbkdfType(ctypes.Structure):
    """struct crypt_pbkdf_type for libcryptsetup."""
    _fields_ = [
        ("type", ctypes.c_char_p),
        ("hash", ctypes.c_char_p),
        ("time_ms", ctypes.c_uint32),
        ("iterations", ctypes.c_uint32),
        ("max_memory_kb", ctypes.c_uint32),
        ("parallel_threads", ctypes.c_uint32),
        ("flags", ctypes.c_uint32),
    ]


def _add_keyslot_by_volume_key(device, volume_key, vk_size, new_passphrase,
                                minimal_pbkdf=False):
    """Add a new keyslot using the volume key. Returns the keyslot number.

    If minimal_pbkdf is True, use pbkdf2 with minimal iterations (for
    high-entropy random passphrases like TPM-sealed secrets).
    """
    lib = _load_libcryptsetup()
    cd = ctypes.c_void_p()
    if lib.crypt_init(ctypes.byref(cd), device.encode()) != 0:
        raise RuntimeError("Failed to open device")
    try:
        if lib.crypt_load(cd, b"LUKS2", None) != 0:
            raise RuntimeError("Failed to load LUKS2 header")
        if minimal_pbkdf:
            pbkdf = _CryptPbkdfType(
                type=b"pbkdf2",
                hash=b"sha512",
                time_ms=1,
                iterations=1000,
                max_memory_kb=0,
                parallel_threads=0,
                flags=0,
            )
            ret = lib.crypt_set_pbkdf_type(cd, ctypes.byref(pbkdf))
            if ret < 0:
                raise RuntimeError(f"crypt_set_pbkdf_type failed: {ret}")
        pw = new_passphrase if isinstance(new_passphrase, bytes) else new_passphrase.encode()
        vk = volume_key if isinstance(volume_key, bytes) else volume_key.encode()
        ret = lib.crypt_keyslot_add_by_volume_key(cd, -1, vk, vk_size, pw, len(pw))
        if ret < 0:
            raise RuntimeError(f"crypt_keyslot_add_by_volume_key failed: {ret}")
        return ret
    finally:
        lib.crypt_free(cd)


def _set_luks_token(device, token_id, token_json):
    """Set or remove a LUKS2 token. token_json=None removes the token.

    Returns the token ID on success.
    """
    lib = _load_libcryptsetup()
    cd = ctypes.c_void_p()
    if lib.crypt_init(ctypes.byref(cd), device.encode()) != 0:
        raise RuntimeError("Failed to open device")
    try:
        if lib.crypt_load(cd, b"LUKS2", None) != 0:
            raise RuntimeError("Failed to load LUKS2 header")
        if token_json is None:
            ret = lib.crypt_token_json_set(cd, token_id, None)
        else:
            j = token_json.encode() if isinstance(token_json, str) else token_json
            ret = lib.crypt_token_json_set(cd, token_id, j)
        if ret < 0:
            raise RuntimeError(f"crypt_token_json_set failed: {ret}")
        return ret
    finally:
        lib.crypt_free(cd)


def _destroy_keyslot(device, slot):
    """Destroy a LUKS2 keyslot."""
    lib = _load_libcryptsetup()
    cd = ctypes.c_void_p()
    if lib.crypt_init(ctypes.byref(cd), device.encode()) != 0:
        raise RuntimeError("Failed to open device")
    try:
        if lib.crypt_load(cd, b"LUKS2", None) != 0:
            raise RuntimeError("Failed to load LUKS2 header")
        ret = lib.crypt_keyslot_destroy(cd, slot)
        if ret < 0:
            raise RuntimeError(f"crypt_keyslot_destroy failed: {ret}")
    finally:
        lib.crypt_free(cd)


def _find_token_for_keyslot(device, slot):
    """Find the token ID associated with a given keyslot, or -1 if none."""
    meta = _get_luks_json(device)
    if not meta:
        return -1
    for tid, tinfo in meta.get("tokens", {}).items():
        if str(slot) in tinfo.get("keyslots", []):
            return int(tid)
    return -1


# ---------------------------------------------------------------------------
# libfido2 ctypes bindings
# ---------------------------------------------------------------------------

# libfido2 constants
FIDO_OK = 0
FIDO_ERR_UP_REQUIRED = 0x11
FIDO_ERR_NO_CREDENTIALS = 0x2E
FIDO_ERR_PIN_NOT_SET = 0x2B
FIDO_ERR_PIN_REQUIRED = 0x36
FIDO_ERR_PIN_INVALID = 0x31
COSE_ES256 = -7
FIDO_EXT_HMAC_SECRET = 0x01
FIDO_OPT_OMIT = 0
FIDO_OPT_FALSE = 1
FIDO_OPT_TRUE = 2


def _load_libfido2():
    """Load libfido2 and set up function prototypes."""
    lib = ctypes.CDLL("libfido2.so.1")

    lib.fido_init.restype = None
    lib.fido_init.argtypes = [ctypes.c_int]

    # Device management
    lib.fido_dev_new.restype = ctypes.c_void_p
    lib.fido_dev_new.argtypes = []

    lib.fido_dev_free.restype = None
    lib.fido_dev_free.argtypes = [ctypes.POINTER(ctypes.c_void_p)]

    lib.fido_dev_open.restype = ctypes.c_int
    lib.fido_dev_open.argtypes = [ctypes.c_void_p, ctypes.c_char_p]

    lib.fido_dev_close.restype = ctypes.c_int
    lib.fido_dev_close.argtypes = [ctypes.c_void_p]

    lib.fido_dev_set_timeout.restype = ctypes.c_int
    lib.fido_dev_set_timeout.argtypes = [ctypes.c_void_p, ctypes.c_int]

    lib.fido_dev_cancel.restype = ctypes.c_int
    lib.fido_dev_cancel.argtypes = [ctypes.c_void_p]

    # Credential creation
    lib.fido_cred_new.restype = ctypes.c_void_p
    lib.fido_cred_new.argtypes = []

    lib.fido_cred_free.restype = None
    lib.fido_cred_free.argtypes = [ctypes.POINTER(ctypes.c_void_p)]

    lib.fido_cred_set_type.restype = ctypes.c_int
    lib.fido_cred_set_type.argtypes = [ctypes.c_void_p, ctypes.c_int]

    lib.fido_cred_set_rp.restype = ctypes.c_int
    lib.fido_cred_set_rp.argtypes = [ctypes.c_void_p, ctypes.c_char_p, ctypes.c_char_p]

    lib.fido_cred_set_user.restype = ctypes.c_int
    lib.fido_cred_set_user.argtypes = [
        ctypes.c_void_p,   # cred
        ctypes.c_char_p,   # user_id
        ctypes.c_size_t,   # user_id_len
        ctypes.c_char_p,   # name
        ctypes.c_char_p,   # display_name
        ctypes.c_char_p,   # icon
    ]

    lib.fido_cred_set_clientdata_hash.restype = ctypes.c_int
    lib.fido_cred_set_clientdata_hash.argtypes = [
        ctypes.c_void_p, ctypes.c_char_p, ctypes.c_size_t
    ]

    lib.fido_cred_set_extensions.restype = ctypes.c_int
    lib.fido_cred_set_extensions.argtypes = [ctypes.c_void_p, ctypes.c_int]

    lib.fido_cred_set_rk.restype = ctypes.c_int
    lib.fido_cred_set_rk.argtypes = [ctypes.c_void_p, ctypes.c_int]

    lib.fido_cred_set_uv.restype = ctypes.c_int
    lib.fido_cred_set_uv.argtypes = [ctypes.c_void_p, ctypes.c_int]

    lib.fido_dev_make_cred.restype = ctypes.c_int
    lib.fido_dev_make_cred.argtypes = [
        ctypes.c_void_p, ctypes.c_void_p, ctypes.c_char_p
    ]

    lib.fido_cred_id_ptr.restype = ctypes.POINTER(ctypes.c_uint8)
    lib.fido_cred_id_ptr.argtypes = [ctypes.c_void_p]

    lib.fido_cred_id_len.restype = ctypes.c_size_t
    lib.fido_cred_id_len.argtypes = [ctypes.c_void_p]

    # Assertion (for hmac-secret retrieval)
    lib.fido_assert_new.restype = ctypes.c_void_p
    lib.fido_assert_new.argtypes = []

    lib.fido_assert_free.restype = None
    lib.fido_assert_free.argtypes = [ctypes.POINTER(ctypes.c_void_p)]

    lib.fido_assert_set_rp.restype = ctypes.c_int
    lib.fido_assert_set_rp.argtypes = [ctypes.c_void_p, ctypes.c_char_p]

    lib.fido_assert_set_clientdata_hash.restype = ctypes.c_int
    lib.fido_assert_set_clientdata_hash.argtypes = [
        ctypes.c_void_p, ctypes.c_char_p, ctypes.c_size_t
    ]

    lib.fido_assert_set_extensions.restype = ctypes.c_int
    lib.fido_assert_set_extensions.argtypes = [ctypes.c_void_p, ctypes.c_int]

    lib.fido_assert_set_hmac_salt.restype = ctypes.c_int
    lib.fido_assert_set_hmac_salt.argtypes = [
        ctypes.c_void_p, ctypes.c_char_p, ctypes.c_size_t
    ]

    lib.fido_assert_allow_cred.restype = ctypes.c_int
    lib.fido_assert_allow_cred.argtypes = [
        ctypes.c_void_p, ctypes.c_char_p, ctypes.c_size_t
    ]

    lib.fido_assert_set_up.restype = ctypes.c_int
    lib.fido_assert_set_up.argtypes = [ctypes.c_void_p, ctypes.c_int]

    lib.fido_assert_set_uv.restype = ctypes.c_int
    lib.fido_assert_set_uv.argtypes = [ctypes.c_void_p, ctypes.c_int]

    lib.fido_dev_get_assert.restype = ctypes.c_int
    lib.fido_dev_get_assert.argtypes = [
        ctypes.c_void_p, ctypes.c_void_p, ctypes.c_char_p
    ]

    lib.fido_assert_hmac_secret_ptr.restype = ctypes.POINTER(ctypes.c_uint8)
    lib.fido_assert_hmac_secret_ptr.argtypes = [ctypes.c_void_p, ctypes.c_size_t]

    lib.fido_assert_hmac_secret_len.restype = ctypes.c_size_t
    lib.fido_assert_hmac_secret_len.argtypes = [ctypes.c_void_p, ctypes.c_size_t]

    # Device enumeration
    lib.fido_dev_info_new.restype = ctypes.c_void_p
    lib.fido_dev_info_new.argtypes = [ctypes.c_size_t]

    lib.fido_dev_info_free.restype = None
    lib.fido_dev_info_free.argtypes = [ctypes.POINTER(ctypes.c_void_p), ctypes.c_size_t]

    lib.fido_dev_info_manifest.restype = ctypes.c_int
    lib.fido_dev_info_manifest.argtypes = [
        ctypes.c_void_p,                    # devlist
        ctypes.c_size_t,                    # ilen (max entries)
        ctypes.POINTER(ctypes.c_size_t),    # olen (actual count, output)
    ]

    lib.fido_dev_info_ptr.restype = ctypes.c_void_p
    lib.fido_dev_info_ptr.argtypes = [ctypes.c_void_p, ctypes.c_size_t]

    lib.fido_dev_info_path.restype = ctypes.c_char_p
    lib.fido_dev_info_path.argtypes = [ctypes.c_void_p]

    # Touch selection (device identification without credentials/PIN)
    lib.fido_dev_get_touch_begin.restype = ctypes.c_int
    lib.fido_dev_get_touch_begin.argtypes = [ctypes.c_void_p]

    lib.fido_dev_get_touch_status.restype = ctypes.c_int
    lib.fido_dev_get_touch_status.argtypes = [
        ctypes.c_void_p,             # dev
        ctypes.POINTER(ctypes.c_int),  # touched (output)
        ctypes.c_int,                # ms (poll timeout)
    ]

    return lib


# FIDO2 RP ID (matches systemd-cryptenroll)
_FIDO2_RP_ID = "io.systemd.cryptsetup"


def _fido2_list_devices(fido2_lib):
    """Discover all FIDO2 device paths using fido_dev_info_manifest.

    Returns a list of device paths as bytes (e.g. [b'/dev/hidraw2', ...]),
    or raises RuntimeError if no FIDO2 device is found.
    """
    max_devs = 16
    devlist = ctypes.c_void_p(fido2_lib.fido_dev_info_new(max_devs))
    if not devlist:
        raise RuntimeError("fido_dev_info_new failed")
    try:
        found = ctypes.c_size_t(0)
        rc = fido2_lib.fido_dev_info_manifest(
            devlist, max_devs, ctypes.byref(found),
        )
        if rc != FIDO_OK or found.value == 0:
            raise RuntimeError("No FIDO2 device found")
        paths = []
        for i in range(found.value):
            di = fido2_lib.fido_dev_info_ptr(devlist, i)
            path = fido2_lib.fido_dev_info_path(di)
            if path:
                paths.append(bytes(path))
        if not paths:
            raise RuntimeError("No FIDO2 device found")
        return paths
    finally:
        fido2_lib.fido_dev_info_free(ctypes.byref(devlist), max_devs)


def _fido2_get_hmac_secret(fido2_lib, dev, cred_id_bytes, salt_bytes, pin=None):
    """Perform a FIDO2 assertion with hmac-secret extension.

    Returns the 32-byte hmac-secret output.
    """
    assert_obj = fido2_lib.fido_assert_new()
    if not assert_obj:
        raise RuntimeError("fido_assert_new failed")
    assert_ptr = ctypes.c_void_p(assert_obj)
    try:
        zeroes = b"\x00" * 32
        fido2_lib.fido_assert_set_rp(assert_ptr, _FIDO2_RP_ID.encode())
        fido2_lib.fido_assert_set_clientdata_hash(assert_ptr, zeroes, 32)
        fido2_lib.fido_assert_set_extensions(assert_ptr, FIDO_EXT_HMAC_SECRET)
        fido2_lib.fido_assert_set_hmac_salt(assert_ptr, salt_bytes, len(salt_bytes))
        fido2_lib.fido_assert_allow_cred(
            assert_ptr, cred_id_bytes, len(cred_id_bytes)
        )
        fido2_lib.fido_assert_set_up(assert_ptr, FIDO_OPT_TRUE)
        fido2_lib.fido_assert_set_uv(assert_ptr, FIDO_OPT_FALSE)

        pin_bytes = pin.encode() if pin else None
        ret = fido2_lib.fido_dev_get_assert(dev, assert_ptr, pin_bytes)
        if ret != FIDO_OK:
            raise RuntimeError(f"fido_dev_get_assert failed: {ret}")

        secret_ptr = fido2_lib.fido_assert_hmac_secret_ptr(assert_ptr, 0)
        secret_len = fido2_lib.fido_assert_hmac_secret_len(assert_ptr, 0)
        if not secret_ptr or secret_len == 0:
            raise RuntimeError("hmac-secret output is empty")
        return bytes(secret_ptr[:secret_len])
    finally:
        fido2_lib.fido_assert_free(ctypes.byref(assert_ptr))


def _fido2_probe_credential(fido2_lib, dev, cred_id):
    """Check if a FIDO2 device holds a credential without using PIN or touch.

    Sends an assertion with UP=false, UV=false, no PIN, no hmac-secret.

    Returns:
      True  — credential confirmed on this device (FIDO_OK, UP_REQUIRED,
              PIN_REQUIRED, or PIN_INVALID — per CTAP2, credential matching
              in the allowList happens before PIN verification, so these
              codes all imply the credential was found)
      False — credential definitely not on this device (NO_CREDENTIALS)
      None  — ambiguous (transport error, unknown code, etc.)

    Callers should use ``is True`` for strict checks (enrolled-status UI)
    and ``is not False`` for optimistic checks (unlock probing).
    """
    assert_obj = fido2_lib.fido_assert_new()
    if not assert_obj:
        return None
    assert_ptr = ctypes.c_void_p(assert_obj)
    try:
        zeroes = b"\x00" * 32
        fido2_lib.fido_assert_set_rp(assert_ptr, _FIDO2_RP_ID.encode())
        fido2_lib.fido_assert_set_clientdata_hash(assert_ptr, zeroes, 32)
        fido2_lib.fido_assert_allow_cred(
            assert_ptr, cred_id, len(cred_id)
        )
        fido2_lib.fido_assert_set_up(assert_ptr, FIDO_OPT_FALSE)
        fido2_lib.fido_assert_set_uv(assert_ptr, FIDO_OPT_OMIT)

        ret = fido2_lib.fido_dev_get_assert(dev, assert_ptr, None)
        print(f"    _fido2_probe_credential: ret={ret:#x}",
              file=sys.stderr)
        if ret == FIDO_ERR_NO_CREDENTIALS:
            return False
        if ret in (FIDO_OK, FIDO_ERR_UP_REQUIRED,
                   FIDO_ERR_PIN_NOT_SET, FIDO_ERR_PIN_REQUIRED,
                   FIDO_ERR_PIN_INVALID):
            return True
        return None
    finally:
        fido2_lib.fido_assert_free(ctypes.byref(assert_ptr))


def _fido2_touch_select(fido2_lib, devs):
    """Make multiple FIDO2 devices blink; return the path of the first touched.

    devs: dict of dev_path -> ctypes.c_void_p (open device handles).
    Uses fido_dev_get_touch_begin/status so no PINs or credentials are involved.
    """
    for dev in devs.values():
        fido2_lib.fido_dev_get_touch_begin(dev)

    while True:
        for path, dev in devs.items():
            touched = ctypes.c_int(0)
            ret = fido2_lib.fido_dev_get_touch_status(
                dev, ctypes.byref(touched), 200,
            )
            if ret == FIDO_OK and touched.value:
                for other_path, other_dev in devs.items():
                    if other_path != path:
                        fido2_lib.fido_dev_cancel(other_dev)
                return path


def _fido2_enroll(fido2_device, pin):
    """Create a FIDO2 credential and get the hmac-secret for LUKS enrollment.

    Returns (cred_id_bytes, salt_bytes, hmac_secret_bytes).
    """
    real_path = os.path.realpath(fido2_device)
    if not re.match(r"^/dev/hidraw\d+$", real_path):
        raise ValueError(f"Invalid FIDO2 device path: {fido2_device}")
    fido2_lib = _load_libfido2()
    fido2_lib.fido_init(0)

    dev = ctypes.c_void_p(fido2_lib.fido_dev_new())
    if not dev:
        raise RuntimeError("fido_dev_new failed")
    try:
        ret = fido2_lib.fido_dev_open(dev, real_path.encode())
        if ret != FIDO_OK:
            raise RuntimeError(f"fido_dev_open({fido2_device}) failed: {ret}")

        # Create credential with hmac-secret extension
        cred = ctypes.c_void_p(fido2_lib.fido_cred_new())
        if not cred:
            raise RuntimeError("fido_cred_new failed")
        try:
            fido2_lib.fido_cred_set_type(cred, COSE_ES256)
            fido2_lib.fido_cred_set_rp(
                cred, _FIDO2_RP_ID.encode(), b"Encrypted Volume"
            )
            user_id = os.urandom(32)
            fido2_lib.fido_cred_set_user(
                cred, user_id, len(user_id),
                b"user", b"user", None
            )
            zeroes = b"\x00" * 32
            fido2_lib.fido_cred_set_clientdata_hash(cred, zeroes, 32)
            fido2_lib.fido_cred_set_extensions(cred, FIDO_EXT_HMAC_SECRET)
            fido2_lib.fido_cred_set_rk(cred, FIDO_OPT_FALSE)
            fido2_lib.fido_cred_set_uv(cred, FIDO_OPT_FALSE)

            pin_bytes = pin.encode() if pin else None
            ret = fido2_lib.fido_dev_make_cred(dev, cred, pin_bytes)
            if ret == FIDO_ERR_PIN_REQUIRED and not pin_bytes:
                raise RuntimeError("FIDO2 device requires a PIN")
            if ret != FIDO_OK:
                raise RuntimeError(f"fido_dev_make_cred failed: {ret}")

            cid_ptr = fido2_lib.fido_cred_id_ptr(cred)
            cid_len = fido2_lib.fido_cred_id_len(cred)
            if not cid_ptr or cid_len == 0:
                raise RuntimeError("Credential ID is empty")
            cred_id = bytes(cid_ptr[:cid_len])
        finally:
            fido2_lib.fido_cred_free(ctypes.byref(cred))

        # Generate random salt and get hmac-secret via assertion
        salt = os.urandom(32)
        hmac_secret = _fido2_get_hmac_secret(fido2_lib, dev, cred_id, salt, pin)
        return cred_id, salt, hmac_secret
    finally:
        fido2_lib.fido_dev_close(dev)
        fido2_lib.fido_dev_free(ctypes.byref(dev))


def _fido2_unlock_from_token(device, pin=""):
    """Read FIDO2 token(s) from LUKS header and derive the passphrase via assertion.

    Three-phase approach to avoid incrementing PIN retry counters on tokens
    the user is not trying to unlock with:

      Phase 1 — Probe each connected device against each enrolled credential
                using UP=false, no PIN, no hmac-secret.  CTAP2 checks
                credentials before PIN, so FIDO_ERR_NO_CREDENTIALS means
                "not on this device" without touching the retry counter.

      Phase 2 — If multiple devices matched, use fido_dev_get_touch_begin /
                fido_dev_get_touch_status to let the user pick one by touch.
                No credentials or PINs involved.

      Phase 3 — Send the real hmac-secret assertion with PIN only to the
                selected device.  User touches once (or again, if phase 2
                was needed) to release the secret.

    Returns the raw passphrase bytes for crypt_volume_key_get.
    """
    meta = _get_luks_json(device)
    if not meta:
        raise RuntimeError("Failed to read LUKS2 metadata")

    fido2_tokens = []
    for _tid, tinfo in meta.get("tokens", {}).items():
        if tinfo.get("type") == "systemd-fido2":
            fido2_tokens.append((
                base64.b64decode(tinfo["fido2-credential"]),
                base64.b64decode(tinfo["fido2-salt"]),
            ))
    if not fido2_tokens:
        raise RuntimeError("No systemd-fido2 token found")

    fido2_lib = _load_libfido2()
    fido2_lib.fido_init(0)

    dev_paths = _fido2_list_devices(fido2_lib)

    # Open all devices up-front; reused across all phases.
    open_devs = {}  # dev_path -> ctypes.c_void_p
    for dev_path in dev_paths:
        dev = ctypes.c_void_p(fido2_lib.fido_dev_new())
        if not dev:
            continue
        ret = fido2_lib.fido_dev_open(dev, dev_path)
        if ret == FIDO_OK:
            open_devs[dev_path] = dev
        else:
            fido2_lib.fido_dev_free(ctypes.byref(dev))

    if not open_devs:
        raise RuntimeError("No FIDO2 device could be opened")

    try:
        # --- Phase 1: Probe (no PIN, no touch) ---
        dev_creds = {}  # dev_path -> [(cred_id, salt), ...]
        for dev_path, dev in open_devs.items():
            matching = []
            for cred_id, salt in fido2_tokens:
                if _fido2_probe_credential(fido2_lib, dev, cred_id) is not False:
                    matching.append((cred_id, salt))
            if matching:
                dev_creds[dev_path] = matching

        if not dev_creds:
            raise RuntimeError("No matching FIDO2 device/credential found")

        # --- Phase 2: Select (touch-to-pick if multiple matches) ---
        if len(dev_creds) == 1:
            selected_path = next(iter(dev_creds))
        else:
            selected_path = _fido2_touch_select(
                fido2_lib, {p: open_devs[p] for p in dev_creds},
            )

        # --- Phase 3: Unlock with PIN on selected device only ---
        selected_dev = open_devs[selected_path]
        fido2_lib.fido_dev_set_timeout(selected_dev, 30000)

        errors = []
        for cred_id, salt in dev_creds[selected_path]:
            try:
                secret = _fido2_get_hmac_secret(
                    fido2_lib, selected_dev, cred_id, salt, pin or None,
                )
                return secret
            except RuntimeError as e:
                errors.append(e)
                continue

        last = errors[-1] if errors else "unknown error"
        raise RuntimeError(f"FIDO2 unlock failed on selected device: {last}")
    finally:
        for dev in open_devs.values():
            fido2_lib.fido_dev_close(dev)
            fido2_lib.fido_dev_free(ctypes.byref(dev))


# ---------------------------------------------------------------------------
# libtss2 ctypes bindings (TPM2)
# ---------------------------------------------------------------------------

# TPM2 constants
TPM2_ALG_RSA = 0x0001
TPM2_ALG_SHA256 = 0x000B
TPM2_ALG_AES = 0x0006
TPM2_ALG_CFB = 0x0043
TPM2_ALG_NULL = 0x0010
TPM2_ALG_ECC = 0x0023
TPM2_ALG_KEYEDHASH = 0x0008
TPM2_ECC_NIST_P256 = 0x0003
TPM2_SE_TRIAL = 0x03
TPM2_SE_POLICY = 0x01
TPM2_RH_OWNER = 0x40000001
TPM2_RS_PW = 0x40000009
ESYS_TR_NONE = 0xFFF
ESYS_TR_PASSWORD = 0x0FF
ESYS_TR_RH_OWNER = 0x101
TPM2_PERSISTENT_SRK = 0x81000001

# TPMA_OBJECT flags
TPMA_OBJECT_FIXEDTPM = 0x00000002
TPMA_OBJECT_FIXEDPARENT = 0x00000010
TPMA_OBJECT_SENSITIVEDATAORIGIN = 0x00000020
TPMA_OBJECT_USERWITHAUTH = 0x00000040
TPMA_OBJECT_NODA = 0x00000400
TPMA_OBJECT_RESTRICTED = 0x00010000
TPMA_OBJECT_DECRYPT = 0x00020000

# Maximum structure sizes for buffer allocation
_TPM2B_PUBLIC_MAX = 1024
_TPM2B_PRIVATE_MAX = 1024
_TPM2B_DIGEST_MAX = 128
_TPM2B_SENSITIVE_CREATE_MAX = 512
_TPML_PCR_SELECTION_MAX = 256
_TPMT_SYM_DEF_MAX = 16
_MARSHAL_BUF_MAX = 4096


def _load_libtss2():
    """Load libtss2-esys and libtss2-mu, set up function prototypes."""
    esys = ctypes.CDLL("libtss2-esys.so.0")
    mu = ctypes.CDLL("libtss2-mu.so.0")

    # TSS2_RC is uint32_t; ESYS_TR is uint32_t; ESYS_CONTEXT* is void*

    esys.Esys_Initialize.restype = ctypes.c_uint32
    esys.Esys_Initialize.argtypes = [
        ctypes.POINTER(ctypes.c_void_p),  # esys_context
        ctypes.c_void_p,                  # tcti (NULL = auto)
        ctypes.c_void_p,                  # abiVersion (NULL = default)
    ]

    esys.Esys_Finalize.restype = None
    esys.Esys_Finalize.argtypes = [ctypes.POINTER(ctypes.c_void_p)]

    esys.Esys_Free.restype = None
    esys.Esys_Free.argtypes = [ctypes.c_void_p]

    esys.Esys_TR_SetAuth.restype = ctypes.c_uint32
    esys.Esys_TR_SetAuth.argtypes = [
        ctypes.c_void_p,  # esys_context
        ctypes.c_uint32,  # handle (ESYS_TR)
        ctypes.c_void_p,  # authValue (TPM2B_AUTH*)
    ]

    esys.Esys_CreatePrimary.restype = ctypes.c_uint32
    esys.Esys_CreatePrimary.argtypes = [
        ctypes.c_void_p,                  # esys_context
        ctypes.c_uint32,                  # primaryHandle (ESYS_TR)
        ctypes.c_uint32,                  # shandle1
        ctypes.c_uint32,                  # shandle2
        ctypes.c_uint32,                  # shandle3
        ctypes.c_void_p,                  # inSensitive (TPM2B_SENSITIVE_CREATE*)
        ctypes.c_void_p,                  # inPublic (TPM2B_PUBLIC*)
        ctypes.c_void_p,                  # outsideInfo (TPM2B_DATA*)
        ctypes.c_void_p,                  # creationPCR (TPML_PCR_SELECTION*)
        ctypes.POINTER(ctypes.c_uint32),  # objectHandle (ESYS_TR*)
        ctypes.POINTER(ctypes.c_void_p),  # outPublic (TPM2B_PUBLIC**)
        ctypes.POINTER(ctypes.c_void_p),  # creationData
        ctypes.POINTER(ctypes.c_void_p),  # creationHash
        ctypes.POINTER(ctypes.c_void_p),  # creationTicket
    ]

    esys.Esys_StartAuthSession.restype = ctypes.c_uint32
    esys.Esys_StartAuthSession.argtypes = [
        ctypes.c_void_p,                  # esys_context
        ctypes.c_uint32,                  # tpmKey (ESYS_TR)
        ctypes.c_uint32,                  # bind (ESYS_TR)
        ctypes.c_uint32,                  # shandle1
        ctypes.c_uint32,                  # shandle2
        ctypes.c_uint32,                  # shandle3
        ctypes.c_void_p,                  # nonceCaller (TPM2B_NONCE*)
        ctypes.c_uint8,                   # sessionType (TPM2_SE)
        ctypes.c_void_p,                  # symmetric (TPMT_SYM_DEF*)
        ctypes.c_uint16,                  # authHash (TPMI_ALG_HASH)
        ctypes.POINTER(ctypes.c_uint32),  # sessionHandle (ESYS_TR*)
    ]

    esys.Esys_PolicyPCR.restype = ctypes.c_uint32
    esys.Esys_PolicyPCR.argtypes = [
        ctypes.c_void_p,  # esys_context
        ctypes.c_uint32,  # policySession (ESYS_TR)
        ctypes.c_uint32,  # shandle1
        ctypes.c_uint32,  # shandle2
        ctypes.c_uint32,  # shandle3
        ctypes.c_void_p,  # pcrDigest (TPM2B_DIGEST*)
        ctypes.c_void_p,  # pcrs (TPML_PCR_SELECTION*)
    ]

    esys.Esys_PolicyAuthValue.restype = ctypes.c_uint32
    esys.Esys_PolicyAuthValue.argtypes = [
        ctypes.c_void_p,  # esys_context
        ctypes.c_uint32,  # policySession
        ctypes.c_uint32,  # shandle1
        ctypes.c_uint32,  # shandle2
        ctypes.c_uint32,  # shandle3
    ]

    esys.Esys_PolicyGetDigest.restype = ctypes.c_uint32
    esys.Esys_PolicyGetDigest.argtypes = [
        ctypes.c_void_p,                  # esys_context
        ctypes.c_uint32,                  # policySession
        ctypes.c_uint32,                  # shandle1
        ctypes.c_uint32,                  # shandle2
        ctypes.c_uint32,                  # shandle3
        ctypes.POINTER(ctypes.c_void_p),  # policyDigest (TPM2B_DIGEST**)
    ]

    esys.Esys_Create.restype = ctypes.c_uint32
    esys.Esys_Create.argtypes = [
        ctypes.c_void_p,                  # esys_context
        ctypes.c_uint32,                  # parentHandle (ESYS_TR)
        ctypes.c_uint32,                  # shandle1
        ctypes.c_uint32,                  # shandle2
        ctypes.c_uint32,                  # shandle3
        ctypes.c_void_p,                  # inSensitive (TPM2B_SENSITIVE_CREATE*)
        ctypes.c_void_p,                  # inPublic (TPM2B_PUBLIC*)
        ctypes.c_void_p,                  # outsideInfo (TPM2B_DATA*)
        ctypes.c_void_p,                  # creationPCR (TPML_PCR_SELECTION*)
        ctypes.POINTER(ctypes.c_void_p),  # outPrivate (TPM2B_PRIVATE**)
        ctypes.POINTER(ctypes.c_void_p),  # outPublic (TPM2B_PUBLIC**)
        ctypes.POINTER(ctypes.c_void_p),  # creationData
        ctypes.POINTER(ctypes.c_void_p),  # creationHash
        ctypes.POINTER(ctypes.c_void_p),  # creationTicket
    ]

    esys.Esys_Load.restype = ctypes.c_uint32
    esys.Esys_Load.argtypes = [
        ctypes.c_void_p,                  # esys_context
        ctypes.c_uint32,                  # parentHandle (ESYS_TR)
        ctypes.c_uint32,                  # shandle1
        ctypes.c_uint32,                  # shandle2
        ctypes.c_uint32,                  # shandle3
        ctypes.c_void_p,                  # inPrivate (TPM2B_PRIVATE*)
        ctypes.c_void_p,                  # inPublic (TPM2B_PUBLIC*)
        ctypes.POINTER(ctypes.c_uint32),  # objectHandle (ESYS_TR*)
    ]

    esys.Esys_Unseal.restype = ctypes.c_uint32
    esys.Esys_Unseal.argtypes = [
        ctypes.c_void_p,                  # esys_context
        ctypes.c_uint32,                  # itemHandle (ESYS_TR)
        ctypes.c_uint32,                  # shandle1 (policy session)
        ctypes.c_uint32,                  # shandle2
        ctypes.c_uint32,                  # shandle3
        ctypes.POINTER(ctypes.c_void_p),  # outData (TPM2B_SENSITIVE_DATA**)
    ]

    esys.Esys_FlushContext.restype = ctypes.c_uint32
    esys.Esys_FlushContext.argtypes = [
        ctypes.c_void_p,  # esys_context
        ctypes.c_uint32,  # flushHandle
    ]

    esys.Esys_TR_FromTPMPublic.restype = ctypes.c_uint32
    esys.Esys_TR_FromTPMPublic.argtypes = [
        ctypes.c_void_p,                  # esys_context
        ctypes.c_uint32,                  # tpm_handle
        ctypes.c_uint32,                  # shandle1
        ctypes.c_uint32,                  # shandle2
        ctypes.c_uint32,                  # shandle3
        ctypes.POINTER(ctypes.c_uint32),  # object (ESYS_TR*)
    ]

    esys.Esys_TR_Serialize.restype = ctypes.c_uint32
    esys.Esys_TR_Serialize.argtypes = [
        ctypes.c_void_p,                  # esys_context
        ctypes.c_uint32,                  # object (ESYS_TR)
        ctypes.POINTER(ctypes.c_void_p),  # buffer (uint8_t**)
        ctypes.POINTER(ctypes.c_size_t),  # buffer_size (size_t*)
    ]

    esys.Esys_ReadPublic.restype = ctypes.c_uint32
    esys.Esys_ReadPublic.argtypes = [
        ctypes.c_void_p,                  # esys_context
        ctypes.c_uint32,                  # objectHandle
        ctypes.c_uint32,                  # shandle1
        ctypes.c_uint32,                  # shandle2
        ctypes.c_uint32,                  # shandle3
        ctypes.POINTER(ctypes.c_void_p),  # outPublic (TPM2B_PUBLIC**)
        ctypes.POINTER(ctypes.c_void_p),  # name
        ctypes.POINTER(ctypes.c_void_p),  # qualifiedName
    ]

    # Marshaling functions
    mu.Tss2_MU_TPM2B_PUBLIC_Marshal.restype = ctypes.c_uint32
    mu.Tss2_MU_TPM2B_PUBLIC_Marshal.argtypes = [
        ctypes.c_void_p,                  # src (TPM2B_PUBLIC*)
        ctypes.c_char_p,                  # buffer
        ctypes.c_size_t,                  # buffer_size
        ctypes.POINTER(ctypes.c_size_t),  # offset
    ]

    mu.Tss2_MU_TPM2B_PUBLIC_Unmarshal.restype = ctypes.c_uint32
    mu.Tss2_MU_TPM2B_PUBLIC_Unmarshal.argtypes = [
        ctypes.c_char_p,                  # buffer
        ctypes.c_size_t,                  # buffer_size
        ctypes.POINTER(ctypes.c_size_t),  # offset
        ctypes.c_void_p,                  # dest (TPM2B_PUBLIC*)
    ]

    mu.Tss2_MU_TPM2B_PRIVATE_Marshal.restype = ctypes.c_uint32
    mu.Tss2_MU_TPM2B_PRIVATE_Marshal.argtypes = [
        ctypes.c_void_p,
        ctypes.c_char_p,
        ctypes.c_size_t,
        ctypes.POINTER(ctypes.c_size_t),
    ]

    mu.Tss2_MU_TPM2B_PRIVATE_Unmarshal.restype = ctypes.c_uint32
    mu.Tss2_MU_TPM2B_PRIVATE_Unmarshal.argtypes = [
        ctypes.c_char_p,
        ctypes.c_size_t,
        ctypes.POINTER(ctypes.c_size_t),
        ctypes.c_void_p,
    ]

    mu.Tss2_MU_TPM2B_SENSITIVE_CREATE_Unmarshal.restype = ctypes.c_uint32
    mu.Tss2_MU_TPM2B_SENSITIVE_CREATE_Unmarshal.argtypes = [
        ctypes.c_char_p,
        ctypes.c_size_t,
        ctypes.POINTER(ctypes.c_size_t),
        ctypes.c_void_p,
    ]

    mu.Tss2_MU_TPML_PCR_SELECTION_Unmarshal.restype = ctypes.c_uint32
    mu.Tss2_MU_TPML_PCR_SELECTION_Unmarshal.argtypes = [
        ctypes.c_char_p,
        ctypes.c_size_t,
        ctypes.POINTER(ctypes.c_size_t),
        ctypes.c_void_p,
    ]

    mu.Tss2_MU_TPM2B_DIGEST_Unmarshal.restype = ctypes.c_uint32
    mu.Tss2_MU_TPM2B_DIGEST_Unmarshal.argtypes = [
        ctypes.c_char_p,
        ctypes.c_size_t,
        ctypes.POINTER(ctypes.c_size_t),
        ctypes.c_void_p,
    ]

    mu.Tss2_MU_TPMT_SYM_DEF_Unmarshal.restype = ctypes.c_uint32
    mu.Tss2_MU_TPMT_SYM_DEF_Unmarshal.argtypes = [
        ctypes.c_char_p,
        ctypes.c_size_t,
        ctypes.POINTER(ctypes.c_size_t),
        ctypes.c_void_p,
    ]

    return esys, mu


def _tpm2_build_pcr_selection(pcrs_str, bank=TPM2_ALG_SHA256):
    """Build TPML_PCR_SELECTION wire-format bytes from a PCR string like '7+11'.

    Wire format: uint32 count + (uint16 hash + uint8 sizeofSelect + bytes pcrSelect)
    """
    pcr_nums = [int(p.strip()) for p in pcrs_str.split("+") if p.strip()]
    if not pcr_nums:
        raise ValueError("PCR selection must not be empty")
    for pcr in pcr_nums:
        if not (0 <= pcr <= 23):
            raise ValueError(f"PCR index {pcr} out of range (0-23)")
    # Build the pcrSelect bitmask (3 bytes = 24 PCRs)
    pcr_select = [0, 0, 0]
    for pcr in pcr_nums:
        pcr_select[pcr // 8] |= (1 << (pcr % 8))
    # TPML_PCR_SELECTION: count(u32) + TPMS_PCR_SELECTION(hash(u16) + sizeofSelect(u8) + pcrSelect)
    return struct.pack(">I H B 3s",
                       1,           # count = 1 bank
                       bank,        # hash algorithm
                       3,           # sizeofSelect
                       bytes(pcr_select))


def _tpm2_build_ecc_srk_template():
    """Build the ECC SRK template as wire-format TPM2B_PUBLIC bytes.

    Matches the TCG TPM2 ECC SRK template used by systemd.
    """

    obj_attrs = (TPMA_OBJECT_FIXEDTPM | TPMA_OBJECT_FIXEDPARENT |
                 TPMA_OBJECT_SENSITIVEDATAORIGIN | TPMA_OBJECT_USERWITHAUTH |
                 TPMA_OBJECT_NODA | TPMA_OBJECT_RESTRICTED | TPMA_OBJECT_DECRYPT)

    # TPMT_PUBLIC in wire format for ECC SRK
    public_area = struct.pack(">HH I H",
                              TPM2_ALG_ECC,      # type
                              TPM2_ALG_SHA256,    # nameAlg
                              obj_attrs,          # objectAttributes
                              0)                  # authPolicy.size = 0
    # TPMS_ECC_PARMS: symmetric + scheme + curveID + kdf
    public_area += struct.pack(">HHH",
                               TPM2_ALG_AES,     # symmetric.algorithm
                               128,              # symmetric.keyBits
                               TPM2_ALG_CFB)     # symmetric.mode
    public_area += struct.pack(">H", TPM2_ALG_NULL)  # scheme
    public_area += struct.pack(">H", TPM2_ECC_NIST_P256)  # curveID
    public_area += struct.pack(">H", TPM2_ALG_NULL)  # kdf
    # TPMS_ECC_POINT unique: x.size=0, y.size=0
    public_area += struct.pack(">HH", 0, 0)

    # TPM2B_PUBLIC: size + publicArea
    return struct.pack(">H", len(public_area)) + public_area


def _tpm2_build_seal_template(policy_digest, use_pin=False):
    """Build sealed object template as wire-format TPM2B_PUBLIC bytes."""

    # Match systemd's sealed object attributes exactly
    obj_attrs = TPMA_OBJECT_FIXEDTPM | TPMA_OBJECT_FIXEDPARENT
    if use_pin:
        obj_attrs |= TPMA_OBJECT_USERWITHAUTH

    # TPMT_PUBLIC for KEYEDHASH sealed object
    public_area = struct.pack(">HH I",
                              TPM2_ALG_KEYEDHASH,  # type
                              TPM2_ALG_SHA256,      # nameAlg
                              obj_attrs)            # objectAttributes
    # authPolicy (the computed policy digest)
    public_area += struct.pack(">H", len(policy_digest)) + policy_digest
    # TPMS_KEYEDHASH_PARMS: scheme = NULL
    public_area += struct.pack(">H", TPM2_ALG_NULL)
    # unique.keyedHash: size = 0
    public_area += struct.pack(">H", 0)

    return struct.pack(">H", len(public_area)) + public_area


def _tpm2_build_sensitive_create(secret, pin=""):
    """Build TPM2B_SENSITIVE_CREATE wire-format bytes."""

    if pin:
        # systemd derives the auth from the PIN via SHA256
        pin_auth = hashlib.sha256(pin.encode()).digest()
    else:
        pin_auth = b""

    # TPMS_SENSITIVE_CREATE: userAuth (TPM2B_AUTH) + data (TPM2B_SENSITIVE_DATA)
    inner = struct.pack(">H", len(pin_auth)) + pin_auth
    inner += struct.pack(">H", len(secret)) + secret

    return struct.pack(">H", len(inner)) + inner


def _tpm2_build_sym_def_null():
    """Build TPMT_SYM_DEF wire-format for NULL algorithm."""
    return struct.pack(">H", TPM2_ALG_NULL)


def _tpm2_build_empty_sensitive_create():
    """Build empty TPM2B_SENSITIVE_CREATE for SRK creation."""
    # TPMS_SENSITIVE_CREATE: userAuth.size=0 + data.size=0
    inner = struct.pack(">HH", 0, 0)
    return struct.pack(">H", len(inner)) + inner


def _tpm2_build_empty_data():
    """Build empty TPM2B_DATA."""
    return struct.pack(">H", 0)


def _tpm2_build_empty_pcr_selection():
    """Build empty TPML_PCR_SELECTION (count=0)."""
    return struct.pack(">I", 0)


def _tpm2_build_empty_digest():
    """Build empty TPM2B_DIGEST (size=0)."""
    return struct.pack(">H", 0)


def _tpm2_unmarshal_to_buf(mu_lib, unmarshal_func, wire_bytes, buf_size):
    """Unmarshal wire-format bytes into a C structure buffer."""
    buf = ctypes.create_string_buffer(buf_size)
    offset = ctypes.c_size_t(0)
    rc = unmarshal_func(wire_bytes, len(wire_bytes), ctypes.byref(offset), buf)
    if rc != 0:
        raise RuntimeError(f"Unmarshal failed: 0x{rc:08x}")
    return buf


def _tpm2_marshal_from_ptr(mu_lib, marshal_func, struct_ptr):
    """Marshal a C structure pointer into wire-format bytes."""
    buf = ctypes.create_string_buffer(_MARSHAL_BUF_MAX)
    offset = ctypes.c_size_t(0)
    rc = marshal_func(struct_ptr, buf, _MARSHAL_BUF_MAX, ctypes.byref(offset))
    if rc != 0:
        raise RuntimeError(f"Marshal failed: 0x{rc:08x}")
    return buf.raw[:offset.value]


def _tpm2_read_tpm2b_size(ptr):
    """Read the uint16 size field from a TPM2B_* structure pointer."""
    raw = ctypes.string_at(ptr, 2)
    return struct.unpack("=H", raw)[0]  # native byte order in C struct


def _tpm2_read_sensitive_data(ptr):
    """Read the data from a TPM2B_SENSITIVE_DATA structure (ESYS output).

    TPM2B_SENSITIVE_DATA layout in C: { uint16 size; uint8 buffer[MAX]; }
    """
    size = _tpm2_read_tpm2b_size(ptr)
    raw = ctypes.string_at(ptr, 2 + size)
    return raw[2:2 + size]


def _tpm2_serialize_tr(esys, ctx, handle):
    """Serialize an ESYS_TR handle using Esys_TR_Serialize.

    Returns the serialized bytes (suitable for tpm2-srk token field).
    """
    buf_ptr = ctypes.c_void_p()
    buf_size = ctypes.c_size_t()
    rc = esys.Esys_TR_Serialize(
        ctx, handle, ctypes.byref(buf_ptr), ctypes.byref(buf_size),
    )
    if rc != 0:
        raise RuntimeError(f"Esys_TR_Serialize failed: 0x{rc:08x}")
    result = ctypes.string_at(buf_ptr.value, buf_size.value)
    esys.Esys_Free(buf_ptr)
    return result


def _tpm2_get_srk(esys, mu, ctx):
    """Get the SRK handle, preferring the persistent SRK at 0x81000001.

    Matches systemd's behavior: use persistent SRK if available,
    otherwise create a transient one via Esys_CreatePrimary.

    Returns (srk_handle_value, need_flush, srk_serialized) where need_flush
    is True if the caller must flush the handle when done, and
    srk_serialized is the Esys_TR_Serialize output bytes for the token.
    """
    srk_handle = ctypes.c_uint32()

    # Try persistent SRK first (standard TCG handle)
    rc = esys.Esys_TR_FromTPMPublic(
        ctx, TPM2_PERSISTENT_SRK,
        ESYS_TR_NONE, ESYS_TR_NONE, ESYS_TR_NONE,
        ctypes.byref(srk_handle),
    )
    if rc == 0:
        srk_blob = _tpm2_serialize_tr(esys, ctx, srk_handle.value)
        return srk_handle.value, False, srk_blob

    # No persistent SRK — create a transient one
    empty_auth_buf = _tpm2_unmarshal_to_buf(
        mu, mu.Tss2_MU_TPM2B_DIGEST_Unmarshal,
        _tpm2_build_empty_digest(), _TPM2B_DIGEST_MAX
    )
    esys.Esys_TR_SetAuth(ctx, ESYS_TR_RH_OWNER, empty_auth_buf)

    srk_pub_in = _tpm2_unmarshal_to_buf(
        mu, mu.Tss2_MU_TPM2B_PUBLIC_Unmarshal,
        _tpm2_build_ecc_srk_template(), _TPM2B_PUBLIC_MAX
    )
    empty_sens_buf = _tpm2_unmarshal_to_buf(
        mu, mu.Tss2_MU_TPM2B_SENSITIVE_CREATE_Unmarshal,
        _tpm2_build_empty_sensitive_create(), _TPM2B_SENSITIVE_CREATE_MAX
    )
    empty_data_buf = _tpm2_unmarshal_to_buf(
        mu, mu.Tss2_MU_TPM2B_DIGEST_Unmarshal,
        _tpm2_build_empty_data(), _TPM2B_DIGEST_MAX
    )
    empty_pcr_buf = _tpm2_unmarshal_to_buf(
        mu, mu.Tss2_MU_TPML_PCR_SELECTION_Unmarshal,
        _tpm2_build_empty_pcr_selection(), _TPML_PCR_SELECTION_MAX
    )

    srk_out_pub = ctypes.c_void_p()
    creation_data = ctypes.c_void_p()
    creation_hash = ctypes.c_void_p()
    creation_ticket = ctypes.c_void_p()

    rc = esys.Esys_CreatePrimary(
        ctx, ESYS_TR_RH_OWNER,
        ESYS_TR_PASSWORD, ESYS_TR_NONE, ESYS_TR_NONE,
        empty_sens_buf, srk_pub_in, empty_data_buf, empty_pcr_buf,
        ctypes.byref(srk_handle),
        ctypes.byref(srk_out_pub),
        ctypes.byref(creation_data),
        ctypes.byref(creation_hash),
        ctypes.byref(creation_ticket),
    )
    if rc != 0:
        raise RuntimeError(f"Esys_CreatePrimary failed: 0x{rc:08x}")

    for p in [srk_out_pub, creation_data, creation_hash, creation_ticket]:
        if p:
            esys.Esys_Free(p)

    srk_blob = _tpm2_serialize_tr(esys, ctx, srk_handle.value)
    return srk_handle.value, True, srk_blob


def _tpm2_seal(secret, pcrs_str, pin=""):
    """Seal a secret to the TPM2 bound to PCR values.

    Returns (blob_bytes, policy_hash_bytes, primary_alg_str, srk_blob_bytes).
    blob_bytes = marshaled TPM2B_PRIVATE + TPM2B_PUBLIC of the sealed object.
    srk_blob_bytes = Esys_TR_Serialize output for the SRK.
    """

    esys, mu = _load_libtss2()

    ctx = ctypes.c_void_p()
    rc = esys.Esys_Initialize(ctypes.byref(ctx), None, None)
    if rc != 0:
        raise RuntimeError(f"Esys_Initialize failed: 0x{rc:08x}")

    trial_session = ctypes.c_uint32()
    to_flush = []

    try:
        # --- Get SRK (persistent at 0x81000001, or create transient) ---
        srk_handle_val, srk_need_flush, srk_blob = _tpm2_get_srk(esys, mu, ctx)
        if srk_need_flush:
            to_flush.append(srk_handle_val)

        # --- Compute policy digest via trial session ---
        sym_def_buf = _tpm2_unmarshal_to_buf(
            mu, mu.Tss2_MU_TPMT_SYM_DEF_Unmarshal,
            _tpm2_build_sym_def_null(), _TPMT_SYM_DEF_MAX
        )

        rc = esys.Esys_StartAuthSession(
            ctx, ESYS_TR_NONE, ESYS_TR_NONE,
            ESYS_TR_NONE, ESYS_TR_NONE, ESYS_TR_NONE,
            None,  # nonceCaller
            TPM2_SE_TRIAL,
            sym_def_buf,
            TPM2_ALG_SHA256,
            ctypes.byref(trial_session),
        )
        if rc != 0:
            raise RuntimeError(f"Esys_StartAuthSession (trial) failed: 0x{rc:08x}")
        to_flush.append(trial_session.value)

        # PolicyPCR
        pcr_sel_buf = _tpm2_unmarshal_to_buf(
            mu, mu.Tss2_MU_TPML_PCR_SELECTION_Unmarshal,
            _tpm2_build_pcr_selection(pcrs_str), _TPML_PCR_SELECTION_MAX
        )

        empty_digest_buf = _tpm2_unmarshal_to_buf(
            mu, mu.Tss2_MU_TPM2B_DIGEST_Unmarshal,
            _tpm2_build_empty_digest(), _TPM2B_DIGEST_MAX
        )

        rc = esys.Esys_PolicyPCR(
            ctx, trial_session.value,
            ESYS_TR_NONE, ESYS_TR_NONE, ESYS_TR_NONE,
            empty_digest_buf, pcr_sel_buf,
        )
        if rc != 0:
            raise RuntimeError(f"Esys_PolicyPCR failed: 0x{rc:08x}")

        # PolicyAuthValue (if PIN is used)
        if pin:
            rc = esys.Esys_PolicyAuthValue(
                ctx, trial_session.value,
                ESYS_TR_NONE, ESYS_TR_NONE, ESYS_TR_NONE,
            )
            if rc != 0:
                raise RuntimeError(f"Esys_PolicyAuthValue failed: 0x{rc:08x}")

        # Get the policy digest
        policy_digest_ptr = ctypes.c_void_p()
        rc = esys.Esys_PolicyGetDigest(
            ctx, trial_session.value,
            ESYS_TR_NONE, ESYS_TR_NONE, ESYS_TR_NONE,
            ctypes.byref(policy_digest_ptr),
        )
        if rc != 0:
            raise RuntimeError(f"Esys_PolicyGetDigest failed: 0x{rc:08x}")

        # Read the policy hash bytes from TPM2B_DIGEST
        policy_size = _tpm2_read_tpm2b_size(policy_digest_ptr.value)
        policy_hash = ctypes.string_at(
            policy_digest_ptr.value + 2, policy_size
        )
        esys.Esys_Free(policy_digest_ptr)

        # Flush trial session
        esys.Esys_FlushContext(ctx, trial_session.value)
        to_flush.remove(trial_session.value)

        # --- Seal the secret ---
        seal_template_wire = _tpm2_build_seal_template(policy_hash, bool(pin))
        seal_pub_in = _tpm2_unmarshal_to_buf(
            mu, mu.Tss2_MU_TPM2B_PUBLIC_Unmarshal,
            seal_template_wire, _TPM2B_PUBLIC_MAX
        )

        seal_sens_buf = _tpm2_unmarshal_to_buf(
            mu, mu.Tss2_MU_TPM2B_SENSITIVE_CREATE_Unmarshal,
            _tpm2_build_sensitive_create(secret, pin),
            _TPM2B_SENSITIVE_CREATE_MAX
        )

        seal_out_priv = ctypes.c_void_p()
        seal_out_pub = ctypes.c_void_p()
        seal_creation_data = ctypes.c_void_p()
        seal_creation_hash = ctypes.c_void_p()
        seal_creation_ticket = ctypes.c_void_p()

        empty_data_buf = _tpm2_unmarshal_to_buf(
            mu, mu.Tss2_MU_TPM2B_DIGEST_Unmarshal,
            _tpm2_build_empty_data(), _TPM2B_DIGEST_MAX
        )
        empty_pcr_buf = _tpm2_unmarshal_to_buf(
            mu, mu.Tss2_MU_TPML_PCR_SELECTION_Unmarshal,
            _tpm2_build_empty_pcr_selection(), _TPML_PCR_SELECTION_MAX
        )

        rc = esys.Esys_Create(
            ctx, srk_handle_val,
            ESYS_TR_PASSWORD, ESYS_TR_NONE, ESYS_TR_NONE,
            seal_sens_buf, seal_pub_in, empty_data_buf, empty_pcr_buf,
            ctypes.byref(seal_out_priv),
            ctypes.byref(seal_out_pub),
            ctypes.byref(seal_creation_data),
            ctypes.byref(seal_creation_hash),
            ctypes.byref(seal_creation_ticket),
        )
        if rc != 0:
            raise RuntimeError(f"Esys_Create (seal) failed: 0x{rc:08x}")

        # Marshal sealed private + public into blob
        priv_wire = _tpm2_marshal_from_ptr(
            mu, mu.Tss2_MU_TPM2B_PRIVATE_Marshal, seal_out_priv
        )
        pub_wire = _tpm2_marshal_from_ptr(
            mu, mu.Tss2_MU_TPM2B_PUBLIC_Marshal, seal_out_pub
        )
        blob = priv_wire + pub_wire

        # Free ESYS outputs
        for p in [seal_out_priv, seal_out_pub, seal_creation_data,
                  seal_creation_hash, seal_creation_ticket]:
            if p:
                esys.Esys_Free(p)

        # Flush SRK (only if we created a transient one)
        if srk_need_flush:
            esys.Esys_FlushContext(ctx, srk_handle_val)
            to_flush.remove(srk_handle_val)

        # Determine primary algorithm name
        primary_alg = "ecc"

        return blob, policy_hash, primary_alg, srk_blob

    finally:
        for h in to_flush:
            try:
                esys.Esys_FlushContext(ctx, h)
            except Exception:
                pass
        esys.Esys_Finalize(ctypes.byref(ctx))


def _tpm2_unseal_from_token(device, pin=""):
    """Read TPM2 token from LUKS header and unseal the secret.

    Tries all systemd-tpm2 tokens on the device.  When a PIN is provided,
    PIN-required tokens are tried first; when no PIN is provided, PIN-less
    tokens are tried first (PIN-required tokens are skipped).

    Returns the raw secret bytes (passphrase) for crypt_volume_key_get.
    """

    meta = _get_luks_json(device)
    if not meta:
        raise RuntimeError("Failed to read LUKS2 metadata")

    # Collect all systemd-tpm2 tokens
    tpm2_tokens = []
    for tid, tinfo in meta.get("tokens", {}).items():
        if tinfo.get("type") == "systemd-tpm2":
            tpm2_tokens.append((tid, tinfo))
    if not tpm2_tokens:
        raise RuntimeError("No systemd-tpm2 token found")

    # Sort: when PIN provided, try PIN-required tokens first;
    # when no PIN, try PIN-less tokens first.
    tpm2_tokens.sort(key=lambda t: t[1].get("tpm2-pin", False) != bool(pin))

    last_error = "No systemd-tpm2 token could be unsealed"

    for tid, tinfo in tpm2_tokens:
        has_pin = tinfo.get("tpm2-pin", False)

        # Skip PIN-required tokens when no PIN provided
        if has_pin and not pin:
            continue

        blob_b64 = tinfo.get("tpm2_blob") or tinfo["tpm2-blob"]
        pcrs = tinfo.get("tpm2-pcrs", [])
        pcr_bank_name = tinfo.get("tpm2-pcr-bank", "sha256")
        primary_alg_name = tinfo.get("tpm2-primary-alg", "ecc")

        # Decode blob
        if isinstance(blob_b64, list):
            blob = b"".join(base64.b64decode(b) for b in blob_b64)
        else:
            blob = base64.b64decode(blob_b64)

        # Build PCR string
        if isinstance(pcrs, list):
            pcrs_str = "+".join(str(p) for p in pcrs)
        else:
            pcrs_str = str(pcrs)

        pcr_bank = {"sha1": 0x0004, "sha256": 0x000B, "sha384": 0x000C,
                    "sha512": 0x000D}.get(pcr_bank_name, TPM2_ALG_SHA256)

        esys, mu = _load_libtss2()

        ctx = ctypes.c_void_p()
        rc = esys.Esys_Initialize(ctypes.byref(ctx), None, None)
        if rc != 0:
            last_error = f"Esys_Initialize failed: 0x{rc:08x}"
            continue

        to_flush = []
        try:
            # --- Get SRK (persistent at 0x81000001, or create transient) ---
            srk_handle_val, srk_need_flush, srk_blob = _tpm2_get_srk(esys, mu, ctx)
            if srk_need_flush:
                to_flush.append(srk_handle_val)

            # Unmarshal the sealed private + public from the blob
            offset = ctypes.c_size_t(0)
            seal_priv_buf = ctypes.create_string_buffer(_TPM2B_PRIVATE_MAX)
            rc = mu.Tss2_MU_TPM2B_PRIVATE_Unmarshal(
                blob, len(blob), ctypes.byref(offset), seal_priv_buf
            )
            if rc != 0:
                last_error = f"Token {tid}: Unmarshal TPM2B_PRIVATE failed: 0x{rc:08x}"
                continue

            seal_pub_buf = ctypes.create_string_buffer(_TPM2B_PUBLIC_MAX)
            rc = mu.Tss2_MU_TPM2B_PUBLIC_Unmarshal(
                blob, len(blob), ctypes.byref(offset), seal_pub_buf
            )
            if rc != 0:
                last_error = f"Token {tid}: Unmarshal TPM2B_PUBLIC failed: 0x{rc:08x}"
                continue

            # Load the sealed object
            loaded_handle = ctypes.c_uint32()
            rc = esys.Esys_Load(
                ctx, srk_handle_val,
                ESYS_TR_PASSWORD, ESYS_TR_NONE, ESYS_TR_NONE,
                seal_priv_buf, seal_pub_buf,
                ctypes.byref(loaded_handle),
            )
            if rc != 0:
                last_error = f"Token {tid}: Esys_Load failed: 0x{rc:08x}"
                continue
            to_flush.append(loaded_handle.value)

            # If PIN is used, set auth on the loaded object
            if has_pin and pin:
                pin_auth = hashlib.sha256(pin.encode()).digest()
                auth_buf2 = ctypes.create_string_buffer(_TPM2B_DIGEST_MAX)
                struct.pack_into("=H", auth_buf2, 0, len(pin_auth))
                ctypes.memmove(
                    ctypes.addressof(auth_buf2) + 2, pin_auth, len(pin_auth)
                )
                esys.Esys_TR_SetAuth(ctx, loaded_handle.value, auth_buf2)

            # Start policy session
            sym_def_buf = _tpm2_unmarshal_to_buf(
                mu, mu.Tss2_MU_TPMT_SYM_DEF_Unmarshal,
                _tpm2_build_sym_def_null(), _TPMT_SYM_DEF_MAX
            )

            policy_session = ctypes.c_uint32()
            rc = esys.Esys_StartAuthSession(
                ctx, ESYS_TR_NONE, ESYS_TR_NONE,
                ESYS_TR_NONE, ESYS_TR_NONE, ESYS_TR_NONE,
                None, TPM2_SE_POLICY, sym_def_buf, TPM2_ALG_SHA256,
                ctypes.byref(policy_session),
            )
            if rc != 0:
                last_error = f"Token {tid}: Esys_StartAuthSession (policy) failed: 0x{rc:08x}"
                continue
            to_flush.append(policy_session.value)

            # Replay PolicyPCR
            pcr_sel_buf = _tpm2_unmarshal_to_buf(
                mu, mu.Tss2_MU_TPML_PCR_SELECTION_Unmarshal,
                _tpm2_build_pcr_selection(pcrs_str, pcr_bank), _TPML_PCR_SELECTION_MAX
            )

            empty_digest_buf = _tpm2_unmarshal_to_buf(
                mu, mu.Tss2_MU_TPM2B_DIGEST_Unmarshal,
                _tpm2_build_empty_digest(), _TPM2B_DIGEST_MAX
            )

            rc = esys.Esys_PolicyPCR(
                ctx, policy_session.value,
                ESYS_TR_NONE, ESYS_TR_NONE, ESYS_TR_NONE,
                empty_digest_buf, pcr_sel_buf,
            )
            if rc != 0:
                last_error = f"Token {tid}: Esys_PolicyPCR failed: 0x{rc:08x}"
                continue

            # PolicyAuthValue if PIN was used
            if has_pin:
                rc = esys.Esys_PolicyAuthValue(
                    ctx, policy_session.value,
                    ESYS_TR_NONE, ESYS_TR_NONE, ESYS_TR_NONE,
                )
                if rc != 0:
                    last_error = f"Token {tid}: Esys_PolicyAuthValue failed: 0x{rc:08x}"
                    continue

            # Unseal
            out_data = ctypes.c_void_p()
            rc = esys.Esys_Unseal(
                ctx, loaded_handle.value,
                policy_session.value, ESYS_TR_NONE, ESYS_TR_NONE,
                ctypes.byref(out_data),
            )
            if rc != 0:
                last_error = f"Token {tid}: Esys_Unseal failed: 0x{rc:08x}"
                continue

            # Read the unsealed secret from TPM2B_SENSITIVE_DATA
            secret = _tpm2_read_sensitive_data(out_data.value)
            esys.Esys_Free(out_data)

            return secret

        finally:
            for h in to_flush:
                try:
                    esys.Esys_FlushContext(ctx, h)
                except Exception:
                    pass
            esys.Esys_Finalize(ctypes.byref(ctx))

    raise RuntimeError(last_error)


SETTINGS_FILE = "/etc/luks-enroll.conf"
SETTINGS_ALLOWED_KEYS = set()  # Add valid keys here as features are added
SETTINGS_DEFAULTS = {
}


def _format_size(size_bytes):
    """Format a byte count as a human-readable string like '32.0 GB'."""
    if size_bytes >= 1_000_000_000_000:
        return f"{size_bytes / 1_000_000_000_000:.1f} TB"
    elif size_bytes >= 1_000_000_000:
        return f"{size_bytes / 1_000_000_000:.1f} GB"
    elif size_bytes >= 1_000_000:
        return f"{size_bytes / 1_000_000:.1f} MB"
    elif size_bytes >= 1_000:
        return f"{size_bytes / 1_000:.1f} KB"
    return f"{size_bytes} B"


def _read_sysfs(path):
    """Read a sysfs file and return its stripped content, or None."""
    try:
        with open(path) as f:
            return f.read().strip()
    except (OSError, IOError):
        return None


def _get_blkid_tag(device, tag):
    """Get a blkid tag (e.g. LABEL, TYPE) for a device, or None."""
    try:
        lib = _load_libblkid()
    except OSError:
        return None

    probe = lib.blkid_new_probe_from_filename(device.encode())
    if not probe:
        return None
    try:
        lib.blkid_probe_set_superblocks_flags(
            probe, _BLKID_SUBLKS_LABEL | _BLKID_SUBLKS_TYPE)
        if lib.blkid_do_safeprobe(probe) != 0:
            return None
        value = ctypes.c_char_p()
        if lib.blkid_probe_lookup_value(
                probe, tag.encode(), ctypes.byref(value), None) != 0:
            return None
        return value.value.decode() if value.value else None
    finally:
        lib.blkid_free_probe(probe)


def _get_parent_device(device):
    """Resolve /dev/sdb1 -> sdb, /dev/sdb -> sdb. Returns the kernel name."""
    basename = os.path.basename(device)
    # Strip trailing partition number: sdb1 -> sdb, nvme0n1p2 -> nvme0n1
    # For nvme style: nvme0n1p1 -> nvme0n1
    match = re.match(r"^(nvme\d+n\d+)p\d+$", basename)
    if match:
        return match.group(1)
    # For sd/vd/hd style: sdb1 -> sdb
    match = re.match(r"^([a-z]+)[0-9]+$", basename)
    if match:
        return match.group(1)
    return basename


def _is_removable(device):
    """Check if a device (e.g. /dev/sdb or /dev/sdb1) is removable."""
    parent = _get_parent_device(device)
    val = _read_sysfs(f"/sys/block/{parent}/removable")
    return val == "1"


def detect_removable_devices():
    """Scan /sys/block/ for removable devices and return device info list."""
    # Get all LUKS devices in one call for efficiency
    luks_devices = set(_blkid_find_luks_devices())

    results = []
    try:
        block_devs = os.listdir("/sys/block")
    except OSError:
        return results

    for dev_name in sorted(block_devs):
        # Skip virtual devices
        if dev_name.startswith(("loop", "ram", "zram")):
            continue

        removable = _read_sysfs(f"/sys/block/{dev_name}/removable")
        if removable != "1":
            continue

        dev_path = f"/dev/{dev_name}"
        size_sectors = _read_sysfs(f"/sys/block/{dev_name}/size")
        size_bytes = int(size_sectors) * 512 if size_sectors else 0
        label = _get_blkid_tag(dev_path, "LABEL") or ""

        # Enumerate partitions
        partitions = []
        try:
            for entry in sorted(os.listdir(f"/sys/block/{dev_name}")):
                if not entry.startswith(dev_name):
                    continue
                part_path = f"/dev/{entry}"
                part_size_sectors = _read_sysfs(
                    f"/sys/block/{dev_name}/{entry}/size"
                )
                part_size_bytes = int(part_size_sectors) * 512 if part_size_sectors else 0
                part_label = _get_blkid_tag(part_path, "LABEL") or ""
                part_encrypted = part_path in luks_devices
                part_info = {
                    "device": part_path,
                    "size": _format_size(part_size_bytes),
                    "label": part_label,
                    "encrypted": part_encrypted,
                }
                if part_encrypted:
                    part_info["luks_device"] = part_path
                partitions.append(part_info)
        except OSError:
            pass

        dev_info = {
            "device": dev_path,
            "partitions": partitions,
            "size": _format_size(size_bytes),
            "label": label,
        }
        results.append(dev_info)

    return results


def get_device_info(device):
    """Return detailed info about a block device as a dict."""
    info = {
        "device": device,
        "size": "",
        "label": "",
        "removable": False,
        "mount_point": "",
        "filesystem": "",
    }

    # Size: use file size for regular files, sysfs for block devices
    if os.path.isfile(device):
        try:
            info["size"] = _format_size(os.path.getsize(device))
        except OSError:
            pass
    else:
        parent = _get_parent_device(device)
        basename = os.path.basename(device)
        size_sectors = _read_sysfs(f"/sys/block/{parent}/{basename}/size")
        if size_sectors is None:
            size_sectors = _read_sysfs(f"/sys/block/{basename}/size")
        if size_sectors:
            info["size"] = _format_size(int(size_sectors) * 512)

    # Label and filesystem from blkid
    info["label"] = _get_blkid_tag(device, "LABEL") or ""
    info["filesystem"] = _get_blkid_tag(device, "TYPE") or ""

    # Removable
    info["removable"] = _is_removable(device)

    # Mount point from /proc/mounts
    try:
        with open("/proc/mounts") as f:
            for line in f:
                parts = line.split()
                if len(parts) >= 2 and parts[0] == device:
                    info["mount_point"] = parts[1]
                    break
    except OSError:
        pass

    return info


def _is_partition(device):
    """Check if device is a partition (vs a whole disk)."""
    basename = os.path.basename(device)
    # /sys/class/block/<dev>/partition exists for partitions
    return os.path.exists(f"/sys/class/block/{basename}/partition")


def _partprobe(device):
    """Tell the kernel to re-read the partition table (BLKRRPART ioctl)."""
    try:
        fd = os.open(device, os.O_RDONLY)
        try:
            fcntl.ioctl(fd, 0x125F)
        finally:
            os.close(fd)
    except OSError:
        pass


def _format_removable_partition(device, passphrase):
    """Format a removable device with LUKS2.

    If device is a whole disk, creates a GPT partition table with a single
    LUKS partition (type 8309), then luksFormat it.
    If device is an existing partition, luksFormat it directly.

    Returns (ok, partition_path, stderr).
    """
    # Safety: refuse non-removable
    if not _is_removable(device):
        return False, "", "Refusing to format non-removable device"

    if _is_partition(device):
        # Existing partition — just wipefs + luksFormat it directly
        ok, stderr = _wipefs(device)
        if not ok:
            return False, "", f"wipefs failed: {stderr}"

        try:
            _luks_format_device(device, passphrase)
        except RuntimeError as e:
            return False, device, f"luksFormat failed: {e}"

        return True, device, ""

    # Whole disk — create GPT + partition

    # Step 1: wipefs
    ok, stderr = _wipefs(device)
    if not ok:
        return False, "", f"wipefs failed: {stderr}"

    # Step 2: zap GPT/MBR and create single LUKS partition
    ok, stderr = _sgdisk_zap_and_partition(device)
    if not ok:
        return False, "", f"GPT partitioning failed: {stderr}"

    # Determine partition path
    dev_basename = os.path.basename(device)
    if re.match(r"^nvme\d+n\d+$", dev_basename):
        partition = f"{device}p1"
    else:
        partition = f"{device}1"

    # Wait for partition device to appear
    for _ in range(20):
        if os.path.exists(partition):
            break
        _partprobe(device)
        time.sleep(0.5)
    else:
        return False, "", f"Partition {partition} did not appear after formatting"

    # Step 4: LUKS format
    try:
        _luks_format_device(partition, passphrase)
    except RuntimeError as e:
        return False, partition, f"luksFormat failed: {e}"

    return True, partition, ""


def _load_setting(key):
    """Read a setting from /etc/luks-enroll.conf."""
    if key not in SETTINGS_ALLOWED_KEYS:
        return ""
    cp = configparser.ConfigParser()
    cp.read(SETTINGS_FILE)
    return cp.get("defaults", key, fallback=SETTINGS_DEFAULTS.get(key, ""))


def _save_setting(key, value):
    """Write a setting to /etc/luks-enroll.conf. Returns True on success."""
    if key not in SETTINGS_ALLOWED_KEYS:
        return False
    cp = configparser.ConfigParser()
    cp.read(SETTINGS_FILE)
    if not cp.has_section("defaults"):
        cp.add_section("defaults")
    cp.set("defaults", key, value)
    try:
        os.makedirs(os.path.dirname(SETTINGS_FILE), exist_ok=True)
        with open(SETTINGS_FILE, "w") as f:
            cp.write(f)
        return True
    except OSError:
        return False


# ---------------------------------------------------------------------------
# Polkit helper
# ---------------------------------------------------------------------------

POLKIT_ACTION_READ = "net.contemno.luks-enroll.read"
POLKIT_ACTION_MANAGE = "net.contemno.luks-enroll.manage"


def check_polkit(connection, invocation, action=POLKIT_ACTION_MANAGE):
    """Check polkit authorization for the caller. Returns True if authorized."""
    try:
        message = invocation.get_message()
        _, caller_pid = message.get_unix_fd_list(), None
        # Get caller PID from the D-Bus connection credentials
        sender = message.get_sender()

        polkit = Gio.DBusProxy.new_sync(
            connection,
            Gio.DBusProxyFlags.NONE,
            None,
            "org.freedesktop.PolicyKit1",
            "/org/freedesktop/PolicyKit1/Authority",
            "org.freedesktop.PolicyKit1.Authority",
            None,
        )

        # Get the caller's PID via D-Bus
        dbus_proxy = Gio.DBusProxy.new_sync(
            connection,
            Gio.DBusProxyFlags.NONE,
            None,
            "org.freedesktop.DBus",
            "/org/freedesktop/DBus",
            "org.freedesktop.DBus",
            None,
        )
        pid_variant = dbus_proxy.call_sync(
            "GetConnectionUnixProcessID",
            GLib.Variant("(s)", (sender,)),
            Gio.DBusCallFlags.NONE,
            -1,
            None,
        )
        caller_pid = pid_variant.unpack()[0]

        # Build the CheckAuthorization parameters manually to ensure
        # correct GVariant types throughout.
        subject = GLib.Variant("(sa{sv})", (
            "unix-process",
            {
                "pid": GLib.Variant("u", caller_pid),
                "start-time": GLib.Variant("t", 0),
            },
        ))
        action_id = GLib.Variant("s", action)
        details = GLib.Variant("a{ss}", {})
        flags = GLib.Variant("u", 1)  # AllowUserInteraction
        cancel_id = GLib.Variant("s", "")

        params = GLib.Variant.new_tuple(subject, action_id, details, flags, cancel_id)

        result = polkit.call_sync(
            "CheckAuthorization",
            params,
            Gio.DBusCallFlags.NONE,
            -1,
            None,
        )

        # Result is ((is_authorized, is_challenge, details),)
        authorized = result.unpack()[0][0]
        return authorized

    except Exception as e:
        print(f"Polkit check failed: {e}", file=sys.stderr)
        return False


