class _FdError(Exception):
    """Raised when a passed UNIX file descriptor fails validation."""


class LuksEnrollService:
    """D-Bus service object for LUKS enrollment operations."""

    def __init__(self, loop):
        self._loop = loop
        self._idle_source_id = None
        self._authorized_senders = {}  # sender -> auth_time (read)
        self._manage_authorized_senders = {}  # sender -> auth_time (manage)
        self._auth_lock = threading.Lock()
        self._reset_idle_timeout()

    def _get_caller_uid(self, connection, sender):
        """Get the UID of the D-Bus caller."""
        dbus_proxy = Gio.DBusProxy.new_sync(
            connection, Gio.DBusProxyFlags.NONE, None,
            "org.freedesktop.DBus", "/org/freedesktop/DBus",
            "org.freedesktop.DBus", None,
        )
        result = dbus_proxy.call_sync(
            "GetConnectionUnixUser",
            GLib.Variant("(s)", (sender,)),
            Gio.DBusCallFlags.NONE, -1, None,
        )
        return result.unpack()[0]

    def _reset_idle_timeout(self):
        """Reset the idle timeout. Called on every method invocation."""
        if self._idle_source_id is not None:
            GLib.source_remove(self._idle_source_id)
        self._idle_source_id = GLib.timeout_add_seconds(
            IDLE_TIMEOUT, self._on_idle_timeout
        )

    def _on_idle_timeout(self):
        """Quit the service after idle timeout."""
        print("Idle timeout reached, exiting.", file=sys.stderr)
        self._loop.quit()
        return GLib.SOURCE_REMOVE

    def handle_method_call(self, connection, sender, object_path, interface_name,
                           method_name, parameters, invocation):
        """Handle incoming D-Bus method calls."""

        # Fd-variant methods: the caller passes a UNIX file descriptor (D-Bus
        # type 'h') as the first arg instead of a device path. Possession of a
        # writable fd is the capability, so these BYPASS polkit and the
        # path-realpath/validation logic. The fd is fstat/access-checked inside
        # each handler. We still reset the idle timer and enforce string caps.
        if method_name.endswith("Fd"):
            self._reset_idle_timeout()
            # Enforce length limits on string parameters (skip the fd handle).
            for arg in parameters.unpack():
                if isinstance(arg, str) and len(arg) > _MAX_PASSPHRASE_LEN:
                    invocation.return_dbus_error(
                        "org.freedesktop.DBus.Error.InvalidArgs",
                        "Parameter exceeds maximum length",
                    )
                    return

            handler = getattr(self, f"_handle_{method_name}", None)
            if handler is None:
                invocation.return_dbus_error(
                    "org.freedesktop.DBus.Error.UnknownMethod",
                    f"Unknown method: {method_name}",
                )
                return

            # Pure metadata reads run inline; all the enroll/wipe/create/verify
            # crypto ops block and must run off the main loop.
            inline_fd_methods = {
                "GetKeyslotsFd", "GetTokensByTypeFd",
                "FindPasswordKeyslotsFd", "GetDeviceInfoFd",
            }
            if method_name in inline_fd_methods:
                try:
                    handler(parameters, invocation)
                except Exception as e:
                    print(f"Method {method_name} failed: {e}", file=sys.stderr)
                    invocation.return_dbus_error(
                        "org.freedesktop.DBus.Error.Failed",
                        "Operation failed",
                    )
            else:
                def _run():
                    try:
                        handler(parameters, invocation)
                    except Exception as e:
                        print(f"Method {method_name} failed: {e}",
                              file=sys.stderr)
                        invocation.return_dbus_error(
                            "org.freedesktop.DBus.Error.Failed",
                            "Operation failed",
                        )
                threading.Thread(target=_run, daemon=True).start()
            return

        # Read-only methods (use POLKIT_ACTION_READ, auth may be cached)
        read_methods = {
            "DetectDevices", "DetectRemovableDevices",
            "GetKeyslots", "GetTokensByType", "FindPasswordKeyslots",
            "GetDeviceInfo", "GetSetting", "CheckFido2Enrolled",
        }

        # Destructive/write methods (use POLKIT_ACTION_MANAGE, never cached)
        write_methods = {
            "VerifyPassphrase", "UnlockWithToken", "EnrollFido2",
            "EnrollTpm2", "EnrollRecoveryKey", "WipeSlot",
            "CreateEncryptedImage", "FormatPartition", "EnrollPassphrase",
            "SetSetting", "Authenticate",
        }

        privileged_methods = read_methods | write_methods

        # Methods whose first parameter is a device/file path
        device_param_methods = {
            "VerifyPassphrase", "UnlockWithToken", "EnrollFido2",
            "EnrollTpm2", "EnrollRecoveryKey", "WipeSlot",
            "EnrollPassphrase", "FormatPartition",
            "GetKeyslots", "GetTokensByType", "FindPasswordKeyslots",
            "GetDeviceInfo", "CheckFido2Enrolled",
        }

        sender = invocation.get_message().get_sender()
        if method_name in privileged_methods:
            polkit_action = (POLKIT_ACTION_READ if method_name in read_methods
                             else POLKIT_ACTION_MANAGE)

            # Check auth cache (read and manage have separate caches/TTLs)
            is_cached = False
            with self._auth_lock:
                if method_name in read_methods:
                    cached_time = self._authorized_senders.get(sender)
                    ttl = AUTH_CACHE_TTL
                else:
                    cached_time = self._manage_authorized_senders.get(sender)
                    ttl = MANAGE_AUTH_CACHE_TTL
                is_cached = (cached_time is not None
                             and (time.monotonic() - cached_time) < ttl)

            if not is_cached:
                # Skip polkit if the caller owns the file they're operating on.
                # Resolve symlinks to prevent a user from tricking the service
                # into operating on files they don't actually own.
                needs_polkit = True
                if method_name in device_param_methods or method_name == "CreateEncryptedImage":
                    try:
                        caller_uid = self._get_caller_uid(connection, sender)
                        path = os.path.realpath(parameters.unpack()[0])
                        if method_name == "CreateEncryptedImage":
                            # File doesn't exist yet — check parent directory
                            parent = os.path.realpath(os.path.dirname(path) or ".")
                            is_dir = os.path.isdir(parent)
                            owner_uid = os.stat(parent).st_uid if is_dir else -1
                            needs_polkit = not (
                                is_dir and owner_uid == caller_uid
                            )
                        else:
                            is_file = os.path.isfile(path)
                            owner_uid = os.stat(path).st_uid if is_file else -1
                            needs_polkit = not (
                                is_file and owner_uid == caller_uid
                            )
                    except Exception as e:
                        print(f"Ownership check failed for {method_name}: {e}",
                              file=sys.stderr)

                if needs_polkit:
                    if not check_polkit(connection, invocation, polkit_action):
                        invocation.return_dbus_error(
                            "org.freedesktop.PolicyKit1.Error.NotAuthorized",
                            "Authorization required for LUKS enrollment operations",
                        )
                        return

                # Cache successful auth
                with self._auth_lock:
                    if method_name in read_methods:
                        self._authorized_senders[sender] = time.monotonic()
                    else:
                        self._manage_authorized_senders[sender] = time.monotonic()
            self._reset_idle_timeout()

        # Resolve device paths to prevent TOCTOU between auth check and handler
        if method_name in device_param_methods:
            args = list(parameters.unpack())
            args[0] = os.path.realpath(args[0])
            # Validate: must be a block device or regular file
            try:
                st_mode = os.stat(args[0]).st_mode
            except OSError:
                invocation.return_dbus_error(
                    "org.freedesktop.DBus.Error.InvalidArgs",
                    "Device path does not exist",
                )
                return
            if not (stat.S_ISBLK(st_mode) or stat.S_ISREG(st_mode)):
                invocation.return_dbus_error(
                    "org.freedesktop.DBus.Error.InvalidArgs",
                    "Path is not a block device or regular file",
                )
                return
            sig = parameters.get_type_string()
            parameters = GLib.Variant(sig, tuple(args))
        elif method_name == "CreateEncryptedImage":
            args = list(parameters.unpack())
            args[0] = os.path.realpath(args[0])
            sig = parameters.get_type_string()
            parameters = GLib.Variant(sig, tuple(args))

        # Enforce length limits on string parameters
        for arg in parameters.unpack():
            if isinstance(arg, str):
                if len(arg) > _MAX_PASSPHRASE_LEN:
                    invocation.return_dbus_error(
                        "org.freedesktop.DBus.Error.InvalidArgs",
                        "Parameter exceeds maximum length",
                    )
                    return

        handler = getattr(self, f"_handle_{method_name}", None)
        if handler is None:
            invocation.return_dbus_error(
                "org.freedesktop.DBus.Error.UnknownMethod",
                f"Unknown method: {method_name}",
            )
            return

        # Methods that may block (crypto ops, FIDO2 touch, TPM2, disk I/O)
        # must run off the main loop so D-Bus stays responsive.
        blocking_methods = {
            "VerifyPassphrase", "UnlockWithToken", "EnrollFido2",
            "EnrollTpm2", "EnrollRecoveryKey", "EnrollPassphrase",
            "WipeSlot", "CreateEncryptedImage", "FormatPartition",
            "CheckFido2Enrolled",
        }

        if method_name in blocking_methods:
            def _run():
                try:
                    handler(parameters, invocation)
                except Exception as e:
                    print(f"Method {method_name} failed: {e}", file=sys.stderr)
                    invocation.return_dbus_error(
                        "org.freedesktop.DBus.Error.Failed",
                        "Operation failed",
                    )
            threading.Thread(target=_run, daemon=True).start()
        else:
            try:
                handler(parameters, invocation)
            except Exception as e:
                print(f"Method {method_name} failed: {e}", file=sys.stderr)
                invocation.return_dbus_error(
                    "org.freedesktop.DBus.Error.Failed",
                    "Operation failed",
                )

    def _handle_DetectDevices(self, parameters, invocation):
        devices = detect_luks_devices()
        invocation.return_value(GLib.Variant("(as)", (devices,)))

    def _handle_GetKeyslots(self, parameters, invocation):
        device = parameters.unpack()[0]
        slots = list_luks_keyslots(device)
        invocation.return_value(GLib.Variant("(s)", (json.dumps(slots),)))

    def _handle_GetTokensByType(self, parameters, invocation):
        device, token_type = parameters.unpack()
        tokens = find_tokens_by_type(device, token_type)
        # Convert list of (token_id, keyslot_list) to JSON-serializable form
        result = [[tid, slots] for tid, slots in tokens]
        invocation.return_value(GLib.Variant("(s)", (json.dumps(result),)))

    def _handle_FindPasswordKeyslots(self, parameters, invocation):
        device = parameters.unpack()[0]
        slots = find_password_keyslots(device)
        invocation.return_value(GLib.Variant("(ai)", (slots,)))

    def _handle_VerifyPassphrase(self, parameters, invocation):
        device, passphrase = parameters.unpack()
        ok, result = verify_luks_passphrase(device, passphrase)
        keyslot = result if isinstance(result, int) else -1
        invocation.return_value(GLib.Variant("(bi)", (ok, keyslot)))

    def _handle_UnlockWithToken(self, parameters, invocation):
        device, token_type, pin = parameters.unpack()
        ok, result = verify_luks_token(device, token_type, pin)
        keyslot = result if isinstance(result, int) else -1
        invocation.return_value(GLib.Variant("(bi)", (ok, keyslot)))

    def _do_EnrollFido2(self, device, passphrase, pin, fido2_device,
                        unlock_method, unlock_pin, invocation):
        try:
            # Reject if this physical token is already enrolled on this volume
            meta = _get_luks_json(device)
            existing_creds = []
            if meta:
                for _tid, tinfo in meta.get("tokens", {}).items():
                    if tinfo.get("type") == "systemd-fido2":
                        existing_creds.append(
                            base64.b64decode(tinfo["fido2-credential"])
                        )
            if existing_creds:
                real_path = os.path.realpath(fido2_device)
                fido2_lib = _load_libfido2()
                fido2_lib.fido_init(0)
                probe_dev = ctypes.c_void_p(fido2_lib.fido_dev_new())
                if probe_dev:
                    try:
                        ret = fido2_lib.fido_dev_open(
                            probe_dev, real_path.encode()
                        )
                        if ret == FIDO_OK:
                            for cred_id in existing_creds:
                                if _fido2_probe_credential(
                                    fido2_lib, probe_dev, cred_id
                                ) is True:
                                    invocation.return_value(GLib.Variant(
                                        "(bss)",
                                        (False, "",
                                         "This FIDO2 token is already "
                                         "enrolled on this volume"),
                                    ))
                                    return
                    finally:
                        fido2_lib.fido_dev_close(probe_dev)
                        fido2_lib.fido_dev_free(ctypes.byref(probe_dev))

            # Create FIDO2 credential and get hmac-secret
            cred_id, salt, hmac_secret = _fido2_enroll(fido2_device, pin or None)

            # Get volume key to add new keyslot
            vk, vk_size = _get_volume_key(
                device, unlock_method, passphrase, unlock_pin
            )

            # Add keyslot using base64-encoded hmac-secret as the passphrase
            # (systemd convention: token plugin base64-encodes secret)
            hmac_secret_b64 = base64.b64encode(hmac_secret)
            keyslot = _add_keyslot_by_volume_key(
                device, vk, vk_size, hmac_secret_b64, minimal_pbkdf=True
            )

            # Store FIDO2 token metadata in LUKS2 header
            token_json = json.dumps({
                "type": "systemd-fido2",
                "keyslots": [str(keyslot)],
                "fido2-credential": base64.b64encode(cred_id).decode(),
                "fido2-salt": base64.b64encode(salt).decode(),
                "fido2-rp": _FIDO2_RP_ID,
                "fido2-clientPin-required": bool(pin),
                "fido2-up-required": True,
                "fido2-uv-required": False,
            })
            _set_luks_token(device, -1, token_json)
            _clear_volume_key_cache(device)

            invocation.return_value(
                GLib.Variant("(bss)", (True, "", ""))
            )
        except Exception as e:
            print(f"EnrollFido2 failed: {e}", file=sys.stderr)
            invocation.return_value(
                GLib.Variant("(bss)", (False, "", "Operation failed"))
            )

    def _handle_EnrollFido2(self, parameters, invocation):
        device, passphrase, pin, fido2_device, unlock_method, unlock_pin = (
            parameters.unpack()
        )
        self._do_EnrollFido2(
            device, passphrase, pin, fido2_device, unlock_method, unlock_pin,
            invocation,
        )

    def _do_CheckFido2Enrolled(self, device, fido2_dev_paths, invocation):
        enrolled_paths = []
        try:
            meta = _get_luks_json(device)
            existing_creds = []
            if meta:
                for _tid, tinfo in meta.get("tokens", {}).items():
                    if tinfo.get("type") == "systemd-fido2":
                        existing_creds.append(
                            base64.b64decode(tinfo["fido2-credential"])
                        )
            print(f"CheckFido2Enrolled: device={device}, "
                  f"fido2_paths={fido2_dev_paths}, "
                  f"existing_creds={len(existing_creds)}",
                  file=sys.stderr)
            if existing_creds and fido2_dev_paths:
                fido2_lib = _load_libfido2()
                fido2_lib.fido_init(0)
                for dev_path in fido2_dev_paths:
                    real_path = os.path.realpath(dev_path)
                    dev = ctypes.c_void_p(fido2_lib.fido_dev_new())
                    if not dev:
                        print(f"  {dev_path}: fido_dev_new failed",
                              file=sys.stderr)
                        continue
                    try:
                        ret = fido2_lib.fido_dev_open(
                            dev, real_path.encode()
                        )
                        if ret != FIDO_OK:
                            print(f"  {dev_path}: fido_dev_open "
                                  f"failed ret={ret:#x}",
                                  file=sys.stderr)
                            continue
                        for cred_id in existing_creds:
                            result = _fido2_probe_credential(
                                fido2_lib, dev, cred_id
                            )
                            print(f"  {dev_path}: probe result="
                                  f"{result}",
                                  file=sys.stderr)
                            if result is True:
                                enrolled_paths.append(dev_path)
                                break
                    finally:
                        fido2_lib.fido_dev_close(dev)
                        fido2_lib.fido_dev_free(ctypes.byref(dev))
        except Exception as e:
            print(f"CheckFido2Enrolled failed: {e}", file=sys.stderr)
        print(f"CheckFido2Enrolled result: {enrolled_paths}",
              file=sys.stderr)
        invocation.return_value(GLib.Variant("(as)", (enrolled_paths,)))

    def _handle_CheckFido2Enrolled(self, parameters, invocation):
        device, fido2_dev_paths = parameters.unpack()
        self._do_CheckFido2Enrolled(device, fido2_dev_paths, invocation)

    def _do_EnrollTpm2(self, device, passphrase, pin, pcrs, unlock_method,
                       unlock_pin, invocation):
        try:

            # Generate random 32-byte secret to seal
            secret = os.urandom(32)

            # Seal the secret to TPM2 bound to PCRs
            blob, policy_hash, primary_alg, srk_blob = _tpm2_seal(
                secret, pcrs, pin
            )

            # Get volume key to add new keyslot
            vk, vk_size = _get_volume_key(
                device, unlock_method, passphrase, unlock_pin
            )

            # Add keyslot using the base64-encoded sealed secret as passphrase
            # (systemd convention: token plugin base64-encodes unsealed bytes)
            secret_b64 = base64.b64encode(secret)
            keyslot = _add_keyslot_by_volume_key(
                device, vk, vk_size, secret_b64, minimal_pbkdf=True
            )

            # Parse PCR list for the token JSON
            pcr_list = [int(p.strip()) for p in pcrs.split("+") if p.strip()]

            # Store TPM2 token metadata in LUKS2 header
            token_json = json.dumps({
                "type": "systemd-tpm2",
                "keyslots": [str(keyslot)],
                "tpm2-blob": base64.b64encode(blob).decode(),
                "tpm2_blob": base64.b64encode(blob).decode(),
                "tpm2-pcrs": pcr_list,
                "tpm2-pcr-bank": "sha256",
                "tpm2-primary-alg": "ecc",
                "tpm2-policy-hash": policy_hash.hex(),
                "tpm2-pin": bool(pin),
                "tpm2_pubkey_pcrs": [],
                "tpm2_pcr_hash": "sha256",
                "tpm2_pcrlock": False,
                "tpm2_srk": base64.b64encode(srk_blob).decode(),
            })
            _set_luks_token(device, -1, token_json)
            _clear_volume_key_cache(device)

            invocation.return_value(
                GLib.Variant("(bss)", (True, "", ""))
            )
        except Exception as e:
            print(f"EnrollTpm2 failed: {e}", file=sys.stderr)
            invocation.return_value(
                GLib.Variant("(bss)", (False, "", "Operation failed"))
            )

    def _handle_EnrollTpm2(self, parameters, invocation):
        device, passphrase, pin, pcrs, unlock_method, unlock_pin = (
            parameters.unpack()
        )
        self._do_EnrollTpm2(
            device, passphrase, pin, pcrs, unlock_method, unlock_pin,
            invocation,
        )

    def _do_EnrollRecoveryKey(self, device, passphrase, unlock_method,
                              unlock_pin, invocation):
        try:
            # Generate modhex recovery key
            recovery_key = _make_recovery_key()

            # Get volume key to add new keyslot
            vk, vk_size = _get_volume_key(
                device, unlock_method, passphrase, unlock_pin
            )

            # Add keyslot using the recovery key as the passphrase
            keyslot = _add_keyslot_by_volume_key(
                device, vk, vk_size, recovery_key
            )

            # Store recovery token metadata in LUKS2 header
            token_json = json.dumps({
                "type": "systemd-recovery",
                "keyslots": [str(keyslot)],
            })
            _set_luks_token(device, -1, token_json)
            _clear_volume_key_cache(device)

            # Return recovery key in stdout (GUI parses it from there)
            invocation.return_value(
                GLib.Variant("(bss)", (True, recovery_key, ""))
            )
        except Exception as e:
            print(f"EnrollRecoveryKey failed: {e}", file=sys.stderr)
            invocation.return_value(
                GLib.Variant("(bss)", (False, "", "Operation failed"))
            )

    def _handle_EnrollRecoveryKey(self, parameters, invocation):
        device, passphrase, unlock_method, unlock_pin = parameters.unpack()
        self._do_EnrollRecoveryKey(
            device, passphrase, unlock_method, unlock_pin, invocation,
        )

    def _do_WipeSlot(self, device, passphrase, unlock_method, pin, slot,
                     invocation):
        try:
            # Verify the caller can unlock the device
            _get_volume_key(device, unlock_method, passphrase, pin)

            # Refuse to wipe the last remaining keyslot
            slots = list_luks_keyslots(device)
            if len(slots) <= 1 and slot in slots:
                invocation.return_value(
                    GLib.Variant("(bss)", (False, "", "Cannot wipe the last remaining keyslot"))
                )
                return

            # Find and remove associated token first
            token_id = _find_token_for_keyslot(device, slot)
            if token_id >= 0:
                _set_luks_token(device, token_id, None)

            # Destroy the keyslot
            _destroy_keyslot(device, slot)
            _clear_volume_key_cache(device)

            invocation.return_value(
                GLib.Variant("(bss)", (True, "", ""))
            )
        except Exception as e:
            print(f"WipeSlot failed: {e}", file=sys.stderr)
            invocation.return_value(
                GLib.Variant("(bss)", (False, "", "Operation failed"))
            )

    def _handle_WipeSlot(self, parameters, invocation):
        device, passphrase, unlock_method, pin, slot = parameters.unpack()
        self._do_WipeSlot(
            device, passphrase, unlock_method, pin, slot, invocation,
        )

    def _handle_CreateEncryptedImage(self, parameters, invocation):
        path, size_mb, passphrase = parameters.unpack()
        real_path = os.path.realpath(path)
        # Reject block devices and paths outside caller-owned directories
        if os.path.exists(real_path) and not os.path.isfile(real_path):
            invocation.return_value(GLib.Variant("(bis)", (False, -1, "Path must be a regular file")))
            return
        # Allowlist: only permit paths under /home/ or /tmp/
        _ALLOWED_PREFIXES = ("/home/", "/tmp/")
        if not any(real_path.startswith(p) for p in _ALLOWED_PREFIXES):
            invocation.return_value(GLib.Variant("(bis)", (False, -1, "Path must be under /home/ or /tmp/")))
            return
        try:
            # Get caller UID/GID to set file ownership
            sender = invocation.get_message().get_sender()
            caller_uid = self._get_caller_uid(invocation.get_connection(), sender)
            caller_gid = pwd.getpwuid(caller_uid).pw_gid

            keyslot = format_luks_image(real_path, size_mb, passphrase)
            os.chown(real_path, caller_uid, caller_gid)
            invocation.return_value(GLib.Variant("(bis)", (True, keyslot, "")))
        except Exception as e:
            print(f"CreateEncryptedImage failed: {e}", file=sys.stderr)
            invocation.return_value(GLib.Variant("(bis)", (False, -1, "Operation failed")))

    def _handle_DetectRemovableDevices(self, parameters, invocation):
        devices = detect_removable_devices()
        invocation.return_value(GLib.Variant("(s)", (json.dumps(devices),)))

    def _handle_GetDeviceInfo(self, parameters, invocation):
        device = parameters.unpack()[0]
        info = get_device_info(device)
        invocation.return_value(GLib.Variant("(s)", (json.dumps(info),)))

    def _handle_FormatPartition(self, parameters, invocation):
        device, passphrase = parameters.unpack()
        ok, partition, stderr = _format_removable_partition(device, passphrase)
        if not ok:
            print(f"FormatPartition failed: {stderr}", file=sys.stderr)
            stderr = "Operation failed"
        invocation.return_value(GLib.Variant("(bss)", (ok, partition, stderr)))

    def _do_EnrollPassphrase(self, device, existing_passphrase, new_passphrase,
                             unlock_method, unlock_pin, invocation):
        try:
            # Get volume key to add new keyslot
            vk, vk_size = _get_volume_key(
                device, unlock_method, existing_passphrase, unlock_pin
            )

            # Add keyslot with the new passphrase
            _add_keyslot_by_volume_key(device, vk, vk_size, new_passphrase)
            _clear_volume_key_cache(device)

            invocation.return_value(
                GLib.Variant("(bss)", (True, "", ""))
            )
        except Exception as e:
            print(f"EnrollPassphrase failed: {e}", file=sys.stderr)
            invocation.return_value(
                GLib.Variant("(bss)", (False, "", "Operation failed"))
            )

    def _handle_EnrollPassphrase(self, parameters, invocation):
        device, existing_passphrase, new_passphrase, unlock_method, unlock_pin = (
            parameters.unpack()
        )
        self._do_EnrollPassphrase(
            device, existing_passphrase, new_passphrase, unlock_method,
            unlock_pin, invocation,
        )

    def _handle_GetSetting(self, parameters, invocation):
        key = parameters.unpack()[0]
        value = _load_setting(key)
        invocation.return_value(GLib.Variant("(s)", (value,)))

    def _handle_SetSetting(self, parameters, invocation):
        key, value = parameters.unpack()
        ok = _save_setting(key, value)
        invocation.return_value(GLib.Variant("(b)", (ok,)))

    def _handle_Authenticate(self, parameters, invocation):
        """No-op method — polkit auth already happened in handle_method_call."""
        invocation.return_value(GLib.Variant("(b)", (True,)))

    def _handle_GetSystemdVersion(self, parameters, invocation):
        # All token operations are now handled natively; return high value
        # so existing GUI version checks always pass.
        invocation.return_value(GLib.Variant("(i)", (999,)))

    # -----------------------------------------------------------------------
    # File-descriptor variants
    #
    # GDBus delivers 'h' args as an index into the message's UnixFDList. We
    # dup the real os-level fd out of the list (we own it; must os.close it),
    # fstat it to confirm a regular file (or block device for non-create ops),
    # check the access mode (O_RDWR for write ops, at least readable for
    # reads), then operate on /proc/self/fd/N so the privileged sandboxed
    # service writes through the client's writable mount under
    # ProtectHome=read-only. Possession of the fd is the capability, so polkit
    # is skipped (done in handle_method_call).
    # -----------------------------------------------------------------------

    @staticmethod
    def _resolve_fd(invocation, parameters, need_write, regular_only=False):
        """Resolve and validate the UNIX fd passed as the first arg.

        Returns (real_fd, path) on success. Raises _FdError on validation
        failure (caller maps it to the operation's failure tuple). The caller
        owns real_fd and must os.close it.
        """
        handle_index = parameters.unpack()[0]
        fd_list = invocation.get_message().get_unix_fd_list()
        if fd_list is None:
            raise _FdError("No file descriptor list in message")
        # Gio.UnixFDList.get dups and returns an os-level fd we own.
        real_fd = fd_list.get(handle_index)
        if real_fd < 0:
            raise _FdError("Invalid file descriptor")
        try:
            st = os.fstat(real_fd)
            is_reg = stat.S_ISREG(st.st_mode)
            is_blk = stat.S_ISBLK(st.st_mode)
            if not (is_reg or (not regular_only and is_blk)):
                raise _FdError("Descriptor is not a regular file")
            flags = fcntl.fcntl(real_fd, fcntl.F_GETFL)
            acc = flags & os.O_ACCMODE
            if need_write:
                if acc != os.O_RDWR:
                    raise _FdError("File descriptor is not writable")
            elif acc == os.O_WRONLY:
                raise _FdError("File descriptor is not readable")
        except OSError as e:
            os.close(real_fd)
            raise _FdError(f"Invalid file descriptor: {e}") from e
        except _FdError:
            os.close(real_fd)
            raise
        return real_fd, f"/proc/self/fd/{real_fd}"

    def _handle_GetKeyslotsFd(self, parameters, invocation):
        real_fd, path = self._resolve_fd(invocation, parameters, need_write=False)
        try:
            slots = list_luks_keyslots(path)
            invocation.return_value(GLib.Variant("(s)", (json.dumps(slots),)))
        finally:
            os.close(real_fd)

    def _handle_GetTokensByTypeFd(self, parameters, invocation):
        token_type = parameters.unpack()[1]
        real_fd, path = self._resolve_fd(invocation, parameters, need_write=False)
        try:
            tokens = find_tokens_by_type(path, token_type)
            result = [[tid, slots] for tid, slots in tokens]
            invocation.return_value(GLib.Variant("(s)", (json.dumps(result),)))
        finally:
            os.close(real_fd)

    def _handle_FindPasswordKeyslotsFd(self, parameters, invocation):
        real_fd, path = self._resolve_fd(invocation, parameters, need_write=False)
        try:
            slots = find_password_keyslots(path)
            invocation.return_value(GLib.Variant("(ai)", (slots,)))
        finally:
            os.close(real_fd)

    def _handle_GetDeviceInfoFd(self, parameters, invocation):
        real_fd, path = self._resolve_fd(invocation, parameters, need_write=False)
        try:
            info = get_device_info(path)
            invocation.return_value(GLib.Variant("(s)", (json.dumps(info),)))
        finally:
            os.close(real_fd)

    def _handle_VerifyPassphraseFd(self, parameters, invocation):
        passphrase = parameters.unpack()[1]
        real_fd, path = self._resolve_fd(invocation, parameters, need_write=False)
        try:
            ok, result = verify_luks_passphrase(path, passphrase)
            keyslot = result if isinstance(result, int) else -1
            invocation.return_value(GLib.Variant("(bi)", (ok, keyslot)))
        finally:
            os.close(real_fd)

    def _handle_UnlockWithTokenFd(self, parameters, invocation):
        token_type, pin = parameters.unpack()[1:]
        try:
            real_fd, path = self._resolve_fd(
                invocation, parameters, need_write=False
            )
        except _FdError as e:
            print(f"UnlockWithTokenFd failed: {e}", file=sys.stderr)
            invocation.return_value(GLib.Variant("(bi)", (False, -1)))
            return
        try:
            ok, result = verify_luks_token(path, token_type, pin)
            keyslot = result if isinstance(result, int) else -1
            invocation.return_value(GLib.Variant("(bi)", (ok, keyslot)))
        except Exception as e:
            print(f"UnlockWithTokenFd failed: {e}", file=sys.stderr)
            invocation.return_value(GLib.Variant("(bi)", (False, -1)))
        finally:
            os.close(real_fd)

    def _handle_CheckFido2EnrolledFd(self, parameters, invocation):
        fido2_dev_paths = parameters.unpack()[1]
        try:
            real_fd, path = self._resolve_fd(
                invocation, parameters, need_write=False
            )
        except _FdError as e:
            print(f"CheckFido2EnrolledFd failed: {e}", file=sys.stderr)
            invocation.return_value(GLib.Variant("(as)", ([],)))
            return
        try:
            self._do_CheckFido2Enrolled(path, fido2_dev_paths, invocation)
        finally:
            os.close(real_fd)

    def _handle_EnrollFido2Fd(self, parameters, invocation):
        _, passphrase, pin, fido2_device, unlock_method, unlock_pin = (
            parameters.unpack()
        )
        try:
            real_fd, path = self._resolve_fd(
                invocation, parameters, need_write=True
            )
        except _FdError as e:
            print(f"EnrollFido2Fd failed: {e}", file=sys.stderr)
            invocation.return_value(
                GLib.Variant("(bss)", (False, "", "Operation failed"))
            )
            return
        try:
            self._do_EnrollFido2(
                path, passphrase, pin, fido2_device, unlock_method,
                unlock_pin, invocation,
            )
        finally:
            os.close(real_fd)

    def _handle_EnrollTpm2Fd(self, parameters, invocation):
        _, passphrase, pin, pcrs, unlock_method, unlock_pin = parameters.unpack()
        try:
            real_fd, path = self._resolve_fd(
                invocation, parameters, need_write=True
            )
        except _FdError as e:
            print(f"EnrollTpm2Fd failed: {e}", file=sys.stderr)
            invocation.return_value(
                GLib.Variant("(bss)", (False, "", "Operation failed"))
            )
            return
        try:
            self._do_EnrollTpm2(
                path, passphrase, pin, pcrs, unlock_method, unlock_pin,
                invocation,
            )
        finally:
            os.close(real_fd)

    def _handle_EnrollRecoveryKeyFd(self, parameters, invocation):
        _, passphrase, unlock_method, unlock_pin = parameters.unpack()
        try:
            real_fd, path = self._resolve_fd(
                invocation, parameters, need_write=True
            )
        except _FdError as e:
            print(f"EnrollRecoveryKeyFd failed: {e}", file=sys.stderr)
            invocation.return_value(
                GLib.Variant("(bss)", (False, "", "Operation failed"))
            )
            return
        try:
            self._do_EnrollRecoveryKey(
                path, passphrase, unlock_method, unlock_pin, invocation,
            )
        finally:
            os.close(real_fd)

    def _handle_EnrollPassphraseFd(self, parameters, invocation):
        _, existing_passphrase, new_passphrase, unlock_method, unlock_pin = (
            parameters.unpack()
        )
        try:
            real_fd, path = self._resolve_fd(
                invocation, parameters, need_write=True
            )
        except _FdError as e:
            print(f"EnrollPassphraseFd failed: {e}", file=sys.stderr)
            invocation.return_value(
                GLib.Variant("(bss)", (False, "", "Operation failed"))
            )
            return
        try:
            self._do_EnrollPassphrase(
                path, existing_passphrase, new_passphrase, unlock_method,
                unlock_pin, invocation,
            )
        finally:
            os.close(real_fd)

    def _handle_WipeSlotFd(self, parameters, invocation):
        _, passphrase, unlock_method, pin, slot = parameters.unpack()
        try:
            real_fd, path = self._resolve_fd(
                invocation, parameters, need_write=True
            )
        except _FdError as e:
            print(f"WipeSlotFd failed: {e}", file=sys.stderr)
            invocation.return_value(
                GLib.Variant("(bss)", (False, "", "Operation failed"))
            )
            return
        try:
            self._do_WipeSlot(
                path, passphrase, unlock_method, pin, slot, invocation,
            )
        finally:
            os.close(real_fd)

    def _handle_CreateEncryptedImageFd(self, parameters, invocation):
        _, size_mb, passphrase = parameters.unpack()
        # Client created the file; the service ftruncates and luksFormats it.
        # NO chown, NO path allowlist (the writable fd is the capability).
        try:
            real_fd, path = self._resolve_fd(
                invocation, parameters, need_write=True, regular_only=True
            )
        except _FdError as e:
            print(f"CreateEncryptedImageFd failed: {e}", file=sys.stderr)
            invocation.return_value(
                GLib.Variant("(bis)", (False, -1, "Operation failed"))
            )
            return
        try:
            if not (1 <= size_mb <= 8192):
                invocation.return_value(GLib.Variant(
                    "(bis)",
                    (False, -1, "size_mb must be between 1 and 8192"),
                ))
                return
            os.ftruncate(real_fd, size_mb * 1024 * 1024)
            keyslot = _luks_format_device(path, passphrase)
            invocation.return_value(GLib.Variant("(bis)", (True, keyslot, "")))
        except Exception as e:
            print(f"CreateEncryptedImageFd failed: {e}", file=sys.stderr)
            invocation.return_value(
                GLib.Variant("(bis)", (False, -1, "Operation failed"))
            )
        finally:
            os.close(real_fd)


# ---------------------------------------------------------------------------
# Bus acquisition
# ---------------------------------------------------------------------------

def on_bus_acquired(connection, name, service):
    """Register the service object on the bus."""
    node_info = Gio.DBusNodeInfo.new_for_xml(INTROSPECTION_XML)
    connection.register_object(
        OBJECT_PATH,
        node_info.interfaces[0],
        service.handle_method_call,
        None,  # get_property
        None,  # set_property
    )
    print(f"Object registered at {OBJECT_PATH}", file=sys.stderr)


def on_name_acquired(connection, name):
    print(f"Acquired bus name: {name}", file=sys.stderr)


def on_name_lost(connection, name, loop):
    print(f"Lost bus name: {name}", file=sys.stderr)
    loop.quit()


# ---------------------------------------------------------------------------
# Main
# ---------------------------------------------------------------------------

def main():
    parser = argparse.ArgumentParser(
        description="D-Bus system service for privileged LUKS enrollment operations"
    )
    parser.add_argument(
        "--replace",
        action="store_true",
        help="Replace existing bus name owner (for development)",
    )
    args = parser.parse_args()

    loop = GLib.MainLoop()
    service = LuksEnrollService(loop)

    flags = Gio.BusNameOwnerFlags.ALLOW_REPLACEMENT
    if args.replace:
        flags |= Gio.BusNameOwnerFlags.REPLACE

    Gio.bus_own_name(
        Gio.BusType.SYSTEM,
        BUS_NAME,
        flags,
        lambda conn, name: on_bus_acquired(conn, name, service),
        lambda conn, name: on_name_acquired(conn, name),
        lambda conn, name: on_name_lost(conn, name, loop),
    )

    try:
        loop.run()
    except KeyboardInterrupt:
        pass


if __name__ == "__main__":
    main()
