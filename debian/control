Source: luks-enroll
Section: admin
Priority: optional
Maintainer: Josh <josh@contemno.net>
# The privileged service is built from the Rust workspace under rust/. The
# C -dev packages below are needed to link libcryptsetup/libblkid/libfido2/
# libtss2; clang/libclang-dev are needed by fido2-sys's bindgen build script.
# The Rust toolchain (cargo/rustc) is provided via rustup in CI rather than
# the distro packages, because the workspace's Cargo.lock is v4 and several
# crates' MSRV exceeds the rustc shipped by stable Debian/Ubuntu; see
# debian/rules.
Build-Depends: debhelper-compat (= 13),
               pkg-config,
               clang,
               libclang-dev,
               libcryptsetup-dev,
               libblkid-dev,
               libfido2-dev,
               libtss2-dev
Standards-Version: 4.6.2
Rules-Requires-Root: no
Homepage: https://github.com/contemno/luks-enroll
Vcs-Git: https://github.com/contemno/luks-enroll.git
Vcs-Browser: https://github.com/contemno/luks-enroll

Package: luks-enroll
# Was "all" while the service was pure-Python; the service is now a compiled
# Rust binary, so the package is architecture-dependent. The GUI client at
# /usr/bin/luks-enroll is still Python (Rust client is Phase B), so the
# python3/GTK deps remain.
Architecture: any
Depends: python3,
         python3-gi,
         gir1.2-gtk-4.0,
         gir1.2-adw-1,
         systemd (>= 248),
         libcryptsetup12,
         libblkid1,
         libfido2-1,
         libtss2-esys-3.0.2-0 | libtss2-esys0,
         libtss2-mu-4.0.1-0 | libtss2-mu0,
         polkitd | policykit-1,
         ${shlibs:Depends},
         ${misc:Depends}
Suggests: dracut
Recommends: tpm2-tools
Description: LUKS Enroll Wizard for LUKS disk encryption
 A GTK4 wizard that guides users through enrolling FIDO2 tokens,
 TPM2 chips, and recovery keys into a LUKS-encrypted root volume,
 then removes the original password keyslot.
 .
 Designed to run on first login or inside a chroot environment.
 .
 FIDO2 token support requires libfido2. TPM2 support requires
 libtss2-esys and libtss2-mu. These are listed as Recommends
 and installed by default on most systems.
 